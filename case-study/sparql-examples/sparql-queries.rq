# ============================================================================
# SPARQL QUERIES - Validation et Analyse de la Knowledge Graph
# ============================================================================
# Ces requêtes permettent de valider et d'analyser les datasets, tasks et
# task categories de manière précise.
# ============================================================================

PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dct: <http://purl.org/dc/terms/>
PREFIX mluo: <http://example.org/mluo/ontology#>
PREFIX mluo_th: <http://example.org/mluo/thesaurus#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX bibo: <http://purl.org/ontology/bibo/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

# ==========================
# 1. VALIDATION DE BASE
# ==========================

# Q1: Compter les datasets sans identifiant
SELECT ?count_without_id WHERE {
  {
    SELECT (COUNT(?ds) AS ?count_without_id) WHERE {
      ?ds a dcat:Dataset .
      FILTER NOT EXISTS { ?ds dct:identifier ?id . }
    }
  }
}

# Q2: Compter les datasets sans métadonnées (title, description)
SELECT ?ds ?has_title ?has_desc WHERE {
  ?ds a dcat:Dataset ;
      dct:identifier ?id .
  OPTIONAL { ?ds dct:title ?title . BIND(BOUND(?title) AS ?has_title) }
  OPTIONAL { ?ds dct:description ?desc . BIND(BOUND(?desc) AS ?has_desc) }
  FILTER (!BOUND(?title) || !BOUND(?desc))
}

# Q3: Datasets sans usage (pas de lien vers Task ou TaskCategory)
SELECT ?ds ?id WHERE {
  ?ds a dcat:Dataset ;
      dct:identifier ?id .
  FILTER NOT EXISTS { ?ds mluo:hasUsage ?u . }
}

# ==========================
# 2. ANALYSE DE COUVERTURE
# ==========================

# Q4: Distribution des tasks par dataset (top 20 datasets)
SELECT ?dataset_id (COUNT(DISTINCT ?task) AS ?task_count) WHERE {
  ?ds a dcat:Dataset ;
      dct:identifier ?dataset_id ;
      mluo:hasUsage ?usage .
  ?usage mluo:hasTask ?task .
}
GROUP BY ?dataset_id
ORDER BY DESC(?task_count)
LIMIT 20

# Q5: Distribution des task categories par dataset
SELECT ?dataset_id (COUNT(DISTINCT ?category) AS ?category_count) WHERE {
  ?ds a dcat:Dataset ;
      dct:identifier ?dataset_id ;
      mluo:hasUsage ?usage .
  ?usage mluo:hasTaskCategory ?category .
}
GROUP BY ?dataset_id
ORDER BY DESC(?category_count)
LIMIT 20

# Q6: Tasks les plus utilisées (top 30)
SELECT ?task (COUNT(DISTINCT ?dataset) AS ?usage_count) WHERE {
  ?dataset a dcat:Dataset ;
           mluo:hasUsage ?usage .
  ?usage mluo:hasTask ?task .
}
GROUP BY ?task
ORDER BY DESC(?usage_count)
LIMIT 30

# Q7: Task Categories les plus utilisées (top 30)
SELECT ?category (COUNT(DISTINCT ?dataset) AS ?usage_count) WHERE {
  ?dataset a dcat:Dataset ;
           mluo:hasUsage ?usage .
  ?usage mluo:hasTaskCategory ?category .
}
GROUP BY ?category
ORDER BY DESC(?usage_count)
LIMIT 30

# ==========================
# 3. VALIDATION D'INTÉGRITÉ
# ==========================

# Q8: Usage sans Task et sans TaskCategory
SELECT ?dataset_id ?usage WHERE {
  ?dataset a dcat:Dataset ;
           dct:identifier ?dataset_id ;
           mluo:hasUsage ?usage .
  FILTER NOT EXISTS { ?usage mluo:hasTask ?t . }
  FILTER NOT EXISTS { ?usage mluo:hasTaskCategory ?c . }
}

# Q9: Vérifier la cohérence Task/TaskCategory (concepts orphelins)
SELECT DISTINCT ?concept 
WHERE {
  ?concept a ?type .
  FILTER (?type = mluo:Task || ?type = mluo:TaskCategory)
  FILTER NOT EXISTS {
    ?usage mluo:hasTask ?concept .
  }
  FILTER NOT EXISTS {
    ?usage mluo:hasTaskCategory ?concept .
  }
}

# Q10: Vérifier les disparités de types (objets sans rdf:type approprié)
SELECT ?resource WHERE {
  {
    ?u mluo:hasTask ?resource .
    FILTER NOT EXISTS { ?resource a mluo:Task . }
  }
  UNION
  {
    ?u mluo:hasTaskCategory ?resource .
    FILTER NOT EXISTS { ?resource a mluo:TaskCategory . }
  }
}

# ==========================
# 4. ANALYSE DE CARDINALITÉ
# ==========================

# Q11: Datasets avec une seule task ou category (potentiellement incomplets)
SELECT ?dataset_id ?total_concepts WHERE {
  ?ds a dcat:Dataset ;
      dct:identifier ?dataset_id ;
      mluo:hasUsage ?usage .
  {
    SELECT ?ds (COUNT(DISTINCT ?t) AS ?total_concepts) WHERE {
      ?ds mluo:hasUsage ?u1 .
      ?u1 mluo:hasTask ?t .
    }
    GROUP BY ?ds
    HAVING (COUNT(DISTINCT ?t) < 2)
  }
}

# Q12: Statistiques globales par dataset (pivot table)
SELECT 
  ?dataset_id 
  (COUNT(DISTINCT ?u) AS ?usage_count)
  (COUNT(DISTINCT ?task) AS ?distinct_tasks)
  (COUNT(DISTINCT ?cat) AS ?distinct_categories)
  (COUNT(DISTINCT ?article) AS ?article_count)
WHERE {
  ?ds a dcat:Dataset ;
      dct:identifier ?dataset_id ;
      mluo:hasUsage ?u .
  OPTIONAL { ?u mluo:hasTask ?task . }
  OPTIONAL { ?u mluo:hasTaskCategory ?cat . }
  OPTIONAL { ?ds mluo:hasAcademicArticle ?article . }
}
GROUP BY ?dataset_id
ORDER BY ?dataset_id

# ==========================
# 5. VALIDATION CROISÉE
# ==========================

# Q13: Comparer le nombre de task links vs task count
SELECT 
  (COUNT(DISTINCT ?usage) AS ?total_usages)
  (COUNT(?task_triple) AS ?total_task_links)
  (COUNT(DISTINCT ?task) AS ?distinct_tasks)
  (ROUND(CAST(COUNT(?task_triple) AS DECIMAL) / COUNT(DISTINCT ?usage)) AS ?avg_tasks_per_usage)
WHERE {
  ?ds a dcat:Dataset ;
      mluo:hasUsage ?usage .
  OPTIONAL { ?usage mluo:hasTask ?task . BIND("link" AS ?task_triple) }
}

# Q14: Datasets avec des tasks et categories mixtes (complexité)
SELECT 
  ?dataset_id 
  (COUNT(DISTINCT ?task) AS ?task_count)
  (COUNT(DISTINCT ?cat) AS ?category_count)
  ?complexity
WHERE {
  ?ds a dcat:Dataset ;
      dct:identifier ?dataset_id ;
      mluo:hasUsage ?u1, ?u2 .
  ?u1 mluo:hasTask ?task .
  ?u2 mluo:hasTaskCategory ?cat .
  BIND(
    IF(COUNT(DISTINCT ?task) > 5 && COUNT(DISTINCT ?cat) > 3, "HIGH",
       IF(COUNT(DISTINCT ?task) > 2 || COUNT(DISTINCT ?cat) > 1, "MEDIUM", "LOW"))
    AS ?complexity
  )
}
GROUP BY ?dataset_id ?complexity

# ==========================
# 6. DÉTECTION D'ANOMALIES
# ==========================

# Q15: Datasets avec des usages vides (n'ont que hasUsage mais sans tasks/categories)
SELECT ?dataset_id (COUNT(?empty_usage) AS ?empty_count) WHERE {
  ?ds a dcat:Dataset ;
      dct:identifier ?dataset_id ;
      mluo:hasUsage ?empty_usage .
  FILTER NOT EXISTS { ?empty_usage mluo:hasTask ?t . }
  FILTER NOT EXISTS { ?empty_usage mluo:hasTaskCategory ?c . }
}
GROUP BY ?dataset_id
HAVING (COUNT(?empty_usage) > 0)

# Q16: Doublets potentiels de tasks/categories (même label, URIs différentes)
SELECT ?label (COUNT(?concept) AS ?count) ?concepts WHERE {
  {
    SELECT ?label (GROUP_CONCAT(DISTINCT STR(?concept)) AS ?concepts) ?concept WHERE {
      ?concept a mluo:Task .
      ?concept rdfs:label ?label .
    }
    GROUP BY ?label ?concept
  }
}
GROUP BY ?label ?concepts
HAVING (COUNT(?concept) > 1)

# ==========================
# 7. ANALYSE MÉTADONNÉES
# ==========================

# Q17: Datasets avec métadonnées incomplètes (manquent titre, description ou keywords)
SELECT 
  ?dataset_id 
  ?has_title 
  ?has_description 
  ?has_keywords 
  ?has_theme
WHERE {
  ?ds a dcat:Dataset ;
      dct:identifier ?dataset_id .
  OPTIONAL { ?ds dct:title ?title . BIND(BOUND(?title) AS ?has_title) }
  OPTIONAL { ?ds dct:description ?description . BIND(BOUND(?description) AS ?has_description) }
  OPTIONAL { ?ds dcat:keyword ?keywords . BIND(BOUND(?keywords) AS ?has_keywords) }
  OPTIONAL { ?ds dcat:theme ?theme . BIND(BOUND(?theme) AS ?has_theme) }
  FILTER(!?has_title || !?has_description || !?has_keywords || !?has_theme)
}
LIMIT 50

# Q18: Datasets éditeur / créateur (si présent)
SELECT ?dataset_id ?creator ?publisher WHERE {
  ?ds a dcat:Dataset ;
      dct:identifier ?dataset_id .
  OPTIONAL { ?ds dct:creator ?creator . }
  OPTIONAL { ?ds dct:publisher ?publisher . }
}
LIMIT 50

# ==========================
# 8. STATISTIQUES AVANCÉES
# ==========================

# Q19: Nombre de datasets par source/origine (basé sur le namespace URI)
SELECT 
  ?source 
  (COUNT(DISTINCT ?ds) AS ?dataset_count)
WHERE {
  ?ds a dcat:Dataset .
  BIND(
    REPLACE(STR(?ds), "^http://example.org/mluo/data#([^/]+)/.*$", "$1")
    AS ?source
  )
}
GROUP BY ?source
ORDER BY DESC(?dataset_count)

# Q20: Matrice de cooccurrence Task-Category (top 20)
SELECT 
  ?task 
  ?category 
  (COUNT(DISTINCT ?ds) AS ?cooccurrence_count)
WHERE {
  ?ds a dcat:Dataset ;
      mluo:hasUsage ?u1, ?u2 .
  ?u1 mluo:hasTask ?task .
  ?u2 mluo:hasTaskCategory ?category .
}
GROUP BY ?task ?category
ORDER BY DESC(?cooccurrence_count)
LIMIT 20
