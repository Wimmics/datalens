mluo_th:audio-text-to-text
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Audio-text-to-text models take both an audio clip and a text prompt as input, and generate natural language text as output. These models can answer questions about spoken content, summarize meetings, analyze music, or interpret speech beyond simple transcription. They are useful for applications that combine speech understanding with reasoning or conversation."@en ;
      skos:inScheme mluo_th:multimodal ;
      skos:prefLabel "Audio Text-to-Text"@en ;
      skos:topConceptOf mluo_th:multimodal .

