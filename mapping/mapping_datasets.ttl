@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix xrr: <http://i3s.unice.fr/xr2rml#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@prefix mluo: <http://example.org/mluo/ontology#> .
@prefix mluo_th: <http://example.org/mluo/thesaurus#> .

# Mapping of raw Hugging Face dataset documents from datasets.json.
#
# Goal:
# Reproduce the same graph shape as kg_generator.py as far as possible from raw
# documents, while excluding parts that require preprocessing (normalized fields
# and precomputed IDs).
#
# Known deliberate differences with output_batch_1.ttl / kg_generator.py:
# - Resource IDs here use sha1(...) because XR2RML 1.3.2 supports sha1() only
#   in templates; kg_generator.py uses SHA-256 based IDs.
# - Normalized/enriched structures are not materialized from raw tags:
#   dcterms:language, dcterms:format/license resources, mluo:hasUsage,
#   mluo:hasAnnotation, mluo:hasModality, prov:wasDerivedFrom, etc.
# - Raw tags are still exposed with dcterms:subject.


<#Dataset>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#dataset/sha1({$.id})";
        rr:termType rr:IRI;
        rr:class dcat:Dataset;
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:identifier;
        rr:objectMap [ xrr:reference "$.id" ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:description;
        rr:objectMap [ xrr:reference "$.description" ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:issued;
        rr:objectMap [ xrr:reference "$.created_at"; rr:datatype xsd:dateTime ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:modified;
        rr:objectMap [ xrr:reference "$.last_modified"; rr:datatype xsd:dateTime ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcat:landingPage;
        rr:objectMap [ rr:template "https://huggingface.co/datasets/{$.id}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcat:distribution;
        rr:objectMap [ rr:template "http://example.org/mluo/data#distribution/sha1({$.id})"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:publisher;
        rr:objectMap [ rr:constant "http://example.org/mluo/data#publisher/HuggingFace"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:spatial;
        rr:objectMap [ rr:constant "http://sws.geonames.org/6252001/"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate mluo:downloadCount;
        rr:objectMap [ xrr:reference "$.downloads"; rr:datatype xsd:integer ];
    ];
    rr:predicateObjectMap [
        rr:predicate mluo:likesCount;
        rr:objectMap [ xrr:reference "$.likes"; rr:datatype xsd:integer ];
    ];
    .


<#DatasetCreatorLink>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, author:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#dataset/sha1({$.id})";
        rr:termType rr:IRI;
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:creator;
        rr:objectMap [ rr:template "http://example.org/mluo/data#creator/{$.author}"; rr:termType rr:IRI ];
    ];
    .


<#DatasetAccessPublic>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, private:false, gated:false})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#dataset/sha1({$.id})";
        rr:termType rr:IRI;
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:accessRights;
        rr:objectMap [ rr:constant "public"; rr:termType rr:Literal ];
    ];
    .


<#DatasetAccessRestricted>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, $or:[{private:true},{gated:true}]})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#dataset/sha1({$.id})";
        rr:termType rr:IRI;
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:accessRights;
        rr:objectMap [ rr:constant "restricted"; rr:termType rr:Literal ];
    ];
    .


<#DatasetAvailabilityTrue>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, disabled:false})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#dataset/sha1({$.id})";
        rr:termType rr:IRI;
    ];
    rr:predicateObjectMap [
        rr:predicate mluo:availabilityStatus;
        rr:objectMap [ rr:constant "true"; rr:datatype xsd:boolean ];
    ];
    .


<#DatasetAvailabilityFalse>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, disabled:true})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#dataset/sha1({$.id})";
        rr:termType rr:IRI;
    ];
    rr:predicateObjectMap [
        rr:predicate mluo:availabilityStatus;
        rr:objectMap [ rr:constant "false"; rr:datatype xsd:boolean ];
    ];
    .


<#DatasetTag>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, tags:{$exists:true}})";
        rml:iterator "$.tags[*]";
        xrr:pushDown [ xrr:reference "$.id"; xrr:as "datasetId" ] ;
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#dataset/sha1({$.datasetId})";
        rr:termType rr:IRI;
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:subject;
        rr:objectMap [ xrr:reference "$" ];
    ];
    .


<#DatasetTagDirect>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, tags:{$exists:true}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#dataset/sha1({$.id})";
        rr:termType rr:IRI;
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:subject;
        rr:objectMap [ xrr:reference "$.tags.*" ];
    ];
    .


<#DatasetLanguageEN>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, tags:'language:en'})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#dataset/sha1({$.id})";
        rr:termType rr:IRI;
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:language;
        rr:objectMap [ rr:constant "http://id.loc.gov/vocabulary/iso639-1/en"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:subject;
        rr:objectMap [ rr:constant "language:en"; rr:termType rr:Literal ];
    ];
    .


<#DatasetModalityText>
