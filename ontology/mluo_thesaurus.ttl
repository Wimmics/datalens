datalens_th:
    dcterms:title "Datalens Thesaurus"@en ;
    dcterms:creator "Aline MENIN", "Zachari ARNAUD" ;
    dcterms:modified "2026-04-24" ;
    dcterms:description "The Datalens Thesaurus provides controlled vocabulary for datasets and machine learning models."@en ;
    owl:versionInfo "1.0" ;
    dcat:landingPage <https://github.com/amenin/datalens> ;
    dcterms:license  <https://www.apache.org/licenses/LICENSE-2.0> ;
    dcterms:created "2026"^^xsd:gYear ;
    dcterms:publisher "Inria", "University Côte d'Azur", "CNRS" .

## Modality Scheme
datalens_th:ModalityScheme a skos:ConceptScheme ;
    skos:prefLabel "Dataset Modality Scheme"@en ;
    skos:definition "A controlled vocabulary for describing the data modality of datasets used in machine learning."@en ;
    skos:hasTopConcept 
        datalens_th:3D,
        datalens_th:Audio,
        datalens_th:Document,
        datalens_th:Geospatial,
        datalens_th:Image,
        datalens_th:Tabular,
        datalens_th:Text,
        datalens_th:TimeSeries,
        datalens_th:Video .

datalens_th:3D a skos:Concept, datalens_o:Modality ;
    skos:prefLabel "3D"@en ;
    skos:definition "Three-dimensional spatial data, such as point clouds or meshes."@en ;
    skos:inScheme datalens_th:ModalityScheme .

datalens_th:Audio a skos:Concept, datalens_o:Modality ;
    skos:prefLabel "Audio"@en ;
    skos:definition "Sound data, such as speech or environmental recordings."@en ;
    skos:inScheme datalens_th:ModalityScheme .

datalens_th:Document a skos:Concept, datalens_o:Modality ;
    skos:prefLabel "Document"@en ;
    skos:definition "Structured textual documents, such as PDFs or HTML pages."@en ;
    skos:inScheme datalens_th:ModalityScheme .

datalens_th:Geospatial a skos:Concept, datalens_o:Modality ;
    skos:prefLabel "Geospatial"@en ;
    skos:definition "Data with spatial/geographic components, such as GIS data."@en ;
    skos:inScheme datalens_th:ModalityScheme .

datalens_th:Image a skos:Concept, datalens_o:Modality ;
    skos:prefLabel "Image"@en ;
    skos:definition "Visual raster data, such as photographs or satellite imagery."@en ;
    skos:inScheme datalens_th:ModalityScheme .

datalens_th:Tabular a skos:Concept, datalens_o:Modality ;
    skos:prefLabel "Tabular"@en ;
    skos:definition "Structured data organized in rows and columns, such as spreadsheets or CSV files."@en ;
    skos:inScheme datalens_th:ModalityScheme .

datalens_th:Text a skos:Concept, datalens_o:Modality ;
    skos:prefLabel "Text"@en ;
    skos:definition "Unstructured or semi-structured plain text data."@en ;
    skos:inScheme datalens_th:ModalityScheme .

datalens_th:TimeSeries a skos:Concept, datalens_o:Modality ;
    skos:prefLabel "Time-series"@en ;
    skos:altLabel "Time series"@en ;
    skos:definition "Sequential data indexed by time, such as sensor readings or stock prices."@en ;
    skos:inScheme datalens_th:ModalityScheme .

datalens_th:Video a skos:Concept, datalens_o:Modality ;
    skos:prefLabel "Video"@en ;
    skos:definition "Temporal sequences of images, optionally with audio."@en ;
    skos:inScheme datalens_th:ModalityScheme .


