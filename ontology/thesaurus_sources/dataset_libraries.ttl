@prefix xrr:     <http://i3s.unice.fr/xr2rml#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .

datalens_th:DatasetLibraryScheme
      a       skos:ConceptScheme ;
      skos:definition "A controlled vocabulary for describing the libraries of dataset resources."@en ;
      skos:prefLabel "Dataset Library Scheme"@en .

datalens_th:datadesigner
      a       skos:Concept , datalens_o:Library ;
      skos:inScheme datalens_th:DatasetLibraryScheme ;
      skos:prefLabel "NeMo Data Designer"@en .

datalens_th:lance
      a       skos:Concept , datalens_o:Library ;
      skos:inScheme datalens_th:DatasetLibraryScheme ;
      skos:prefLabel "Lance"@en .

datalens_th:datasets
      a       skos:Concept , datalens_o:Library ;
      skos:inScheme datalens_th:DatasetLibraryScheme ;
      skos:prefLabel "Datasets"@en .

datalens_th:webdataset
      a       skos:Concept , datalens_o:Library ;
      skos:inScheme datalens_th:DatasetLibraryScheme ;
      skos:prefLabel "WebDataset"@en .

datalens_th:polars
      a       skos:Concept , datalens_o:Library ;
      skos:inScheme datalens_th:DatasetLibraryScheme ;
      skos:prefLabel "Polars"@en .

datalens_th:dask
      a       skos:Concept , datalens_o:Library ;
      skos:inScheme datalens_th:DatasetLibraryScheme ;
      skos:prefLabel "Dask"@en .

datalens_th:pandas
      a       skos:Concept , datalens_o:Library ;
      skos:inScheme datalens_th:DatasetLibraryScheme ;
      skos:prefLabel "pandas"@en .

datalens_th:fiftyone
      a       skos:Concept , datalens_o:Library ;
      skos:inScheme datalens_th:DatasetLibraryScheme ;
      skos:prefLabel "FiftyOne"@en .

datalens_th:distilabel
      a       skos:Concept , datalens_o:Library ;
      skos:inScheme datalens_th:DatasetLibraryScheme ;
      skos:prefLabel "Distilabel"@en .

datalens_th:mlcroissant
      a       skos:Concept , datalens_o:Library ;
      skos:inScheme datalens_th:DatasetLibraryScheme ;
      skos:prefLabel "Croissant"@en .

datalens_th:argilla
      a       skos:Concept , datalens_o:Library ;
      skos:inScheme datalens_th:DatasetLibraryScheme ;
      skos:prefLabel "Argilla"@en .
