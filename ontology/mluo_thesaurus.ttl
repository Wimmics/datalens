mluo_th:hate-speech-detection a skos:Concept, mluo:Task ;
    skos:prefLabel "Hate Speech Detection"@en ;
    skos:inScheme mluo_th:TaskScheme ;
    skos:broader mluo_th:text-classification .

mluo_th:multi-class-image-classification a skos:Concept, mluo:Task ;
    skos:prefLabel "Multi Class Image Classification"@en ;
    skos:inScheme mluo_th:TaskScheme ;
    skos:broader mluo_th:image-classification .

mluo_th:sentiment-scoring a skos:Concept, mluo:Task ;
