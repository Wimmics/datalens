<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>DataLens</title>

    <link rel="stylesheet" type="text/css" href="/datalens/css/main.css" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>

    <!-- Include the noUiSlider CSS and JS libraries -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/noUiSlider/14.7.0/nouislider.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/noUiSlider/14.7.0/nouislider.min.js"></script>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/d3/5.16.0/d3.min.js" integrity="sha512-FHsFVKQ/T1KWJDGSbrUhTJyS1ph3eRrxI228ND0EGaEp6v4a/vGwPWd3Dtd/+9cI7ccofZvl/wulICEurHN1pg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    <script src="https://cdn.jsdelivr.net/npm/simple-statistics@7.8.3/dist/simple-statistics.min.js"></script>

    <script src="/datalens/js/filterpanel.js"></script>
    <script src="/datalens/js/dataviz.js"></script>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">DataLens</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/datalens">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/datalens/explorer">Explorer</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <!-- Main Content -->
    <div class="container-fluid mt-4">
        <div class="d-flex" style="height: 90vh;">
        <!-- Resizable Sidebar -->
        <div id="resizable-sidebar" style="width: 300px; min-width: 250px; max-width: 600px;">
            <div class="card h-100 d-flex flex-column gap-2">
    
            <!-- Top Card -->
            <div class="card card-bottom" style="height: 30%; overflow-y: scroll;">
                <div class="card-header">
                Network Topology Editor
                </div>
                <div class="card-body d-flex align-items-center" style="gap: 10px;">
                <div class="flex-grow-1">
                    <div class="form-group">
                    <label for="source-select">Source Node</label>
                    <select class="form-control" id="source-select"></select>
                    </div>
                    <div class="form-group">
                    <label for="target-select">Target Node</label>
                    <select class="form-control" id="target-select"></select>
                    </div>
                    <div class="form-group">
                    <label for="link-select">Link</label>
                    <select class="form-control" id="link-select"></select>
                    </div>
                    <div class="form-group">
                    <label for="theme-select">Thematic Variable</label>
                    <select class="form-control" id="theme-select"></select>
                    </div>
                </div>
                <button type="button" class="btn btn-primary ml-3 align-self-stretch" id="btn-build-network">
                    <i class="fas fa-play"></i>
                </button>
                </div>
            </div>
    
            <!-- Bottom Card -->
            <div class="card card-top" style="height: 70%;">
                <div class="card-header">
                Filtering Panel
                </div>
                <div class="card-body" id="filters-container" style="overflow-y: scroll;"></div>
            </div>
            </div>
        </div>
    
        <!-- Resizer Handle -->
        <div id="resizer" style="width: 5px; cursor: ew-resize; background: #ccc;"></div>
    
        <!-- Main Visualization Panel -->
        <div class="flex-grow-1 ml-2">
            <div class="card h-100">
            <div class="card-header" id="viz-title">
                Visualization
            </div>
            <div class="card-body">
                <div class="dashboard">
                <div id="placeholder" class="placeholder-message hidden">
                    Please select at least one filter.
                </div>
                <!-- <mge-dashboard id="visualization-content"></mge-dashboard> -->
                </div>
            </div>
            </div>
        </div>
        </div>
    </div>    
  

    <!-- Footer Section -->
  <footer class="bg-light text-center" style="height: 50px; display: flex; justify-content: center; align-items: center; gap: 15px;">
    <div style="display: flex; justify-content: center; align-items: center; gap: 10px;">
      <img src="/datalens/images/logos/uca.png" alt="UCA" style="height: 20px;">
      <img src="/datalens/images/logos/cnrs.png" alt="CNRS" style="height: 20px;">
      <img src="/datalens/images/logos/inria.png" alt="Inria" style="height: 20px;">
      <img src="/datalens/images/logos/i3s.png" alt="I3S" style="height: 20px;">
      <img src="/datalens/images/logos/wimmics.png" alt="Wimmics" style="height: 20px;">
    </div>
    <p style="margin: 0; padding-left: 15px; line-height: 40px; font-size: 12px;">&copy; 2024 DataLens. All rights reserved.</p>
  </footer>

</body>



<script type="module">
    // console.log( <%- JSON.stringify(locals) %> )

    import '/datalens/node_modules/mgexplorer/dist/mgexplorer/mgexplorer.esm.js';

    // let locals = <%- JSON.stringify(locals) %>;


    document.addEventListener('DOMContentLoaded', async () => {

        let savedFilters = window.sessionStorage.getItem('filters')

        const filterPanel = new FilterPanel(savedFilters)
        await filterPanel.set()

        const dataviz = new DataViz()
        await dataviz.init()
        
        document.querySelector("#btn-build-network").addEventListener('click', async () => {

            let filters = { ...filterPanel.getSelectedFilters() }
            filters.source = document.querySelector('#source-select').value
            filters.target = document.querySelector('#target-select').value
            filters.link = document.querySelector("#link-select").value
            filters.theme = document.querySelector("#theme-select").value

            window.sessionStorage.setItem('filters', JSON.stringify(filters))

            console.log(filters)

            if (filters.link === 'dataset' && (filters.source === 'dataset' || filters.target === 'dataset'))
                dataviz.togglePlaceholder(`<i class="fa-solid fa-triangle-exclamation alert-icon"></i><br>"Dataset" cannot be both node and link. Please modify your selection`)

            else if (Object.keys(filters).length > 0 && Object.values(filters).some(arr => arr.length > 0)) {
                // await dataviz.reset()
                dataviz.set(filters)
            }
        })
        
    })

    // Resizable Sidebar Functionality
    // This script allows the sidebar to be resized by dragging the resizer handle.
    const resizer = document.getElementById('resizer');
    const sidebar = document.getElementById('resizable-sidebar');

    let isResizing = false;

    resizer.addEventListener('mousedown', function (e) {
        isResizing = true;
        document.body.style.cursor = 'ew-resize';
    });

    document.addEventListener('mousemove', function (e) {
        if (!isResizing) return;
        
        const newWidth = e.clientX;
        if (newWidth >= 250 && newWidth <= 600) {
            sidebar.style.width = `${newWidth}px`;
        }
    });

    document.addEventListener('mouseup', function () {
        isResizing = false;
        document.body.style.cursor = '';
    });
 

    
</script>

</html>