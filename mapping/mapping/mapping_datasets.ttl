        rr:predicate dcterms:subject;
        rr:objectMap [ rr:template "http://example.org/mluo/thesaurus#{$.task_id}"; rr:termType rr:IRI ];
    ];
    .

<#DatasetModality>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.datasets_modalities.find({dataset_hash16:{$exists:true}, modality:{$exists:true,$ne:null}})";
