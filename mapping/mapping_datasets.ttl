        rr:template "http://example.org/mluo/data#dataset/sha1({$.id})";
        rr:termType rr:IRI;
    ];
    rr:predicateObjectMap [
        rr:predicate mluo:rowsSize;
        rr:objectMap [ rr:constant "['n<1K']"; rr:termType rr:Literal ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:subject;
        rr:objectMap [ rr:constant "size_categories:n<1K"; rr:termType rr:Literal ];
    ];
    .


