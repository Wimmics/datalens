      skos:prefLabel "Multivariate Time Series Forecasting"@en .

mluo_th:sentence-similarity
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Sentence Similarity is the task of determining how similar two texts are. Sentence similarity models convert input texts into vectors (embeddings) that capture semantic information and calculate how close (similar) they are between them. This task is particularly useful for information retrieval and clustering/grouping."@en ;
      skos:inScheme mluo_th:nlp ;
      skos:prefLabel "Sentence Similarity"@en ;
      skos:topConceptOf mluo_th:nlp .

mluo_th:text-to-3d
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text-to-3D models take in text input and produce 3D output."@en ;
      skos:inScheme mluo_th:cv ;
      skos:prefLabel "Text-to-3D"@en ;
      skos:topConceptOf mluo_th:cv .

