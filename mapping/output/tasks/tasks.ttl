mluo_th:named-entity-recognition
      a       skos:Concept , mluo:Task ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_ids> ;
      skos:broader mluo_th:token-classification ;
      skos:prefLabel "Named Entity Recognition"@en .

mluo_th:document-question-answering
      a       mluo:TaskCategory , skos:Concept , mluo:Task ;
      dcterms:source <https://huggingface.co/api/tasks> , <https://huggingface.co/api/datasets-tags-by-type?type=task_ids> ;
      skos:definition "Document Question Answering (also known as Document Visual Question Answering) is the task of answering questions on document images. Document question answering models take a (document, question) pair as input and return an answer in natural language. Models usually rely on multi-modal features, combining text, position of words (bounding-boxes) and image."@en ;
      skos:inScheme mluo_th:multimodal ;
      skos:prefLabel "Document Question Answering"@en ;
      skos:topConceptOf mluo_th:multimodal .

mluo_th:open-domain-abstractive-qa
      a       skos:Concept , mluo:Task ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_ids> ;
      skos:broader mluo_th:question-answering ;
      skos:prefLabel "Open Domain Abstractive QA"@en .

mluo_th:entity-linking-retrieval
      a       skos:Concept , mluo:Task ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_ids> ;
      skos:broader mluo_th:text-retrieval ;
      skos:prefLabel "Entity Linking Retrieval"@en .

mluo_th:explanation-generation
      a       skos:Concept , mluo:Task ;
