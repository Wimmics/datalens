@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix oa: <http://www.w3.org/ns/oa#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .

@prefix mluo: <http://example.org/mluo/ontology#> .
@prefix mluo_th: <http://example.org/mluo/thesaurus#> .

@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix xrr:    <http://i3s.unice.fr/xr2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .

# ----------------------------------- Scheme

<#SchemeFromModelAPI>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.task_categories_api.find({task_categories:{$exists:true}})";
        rml:iterator "$.task_categories.*";
    ];
    rr:subjectMap [ 
        rr:template "http://example.org/mluo/thesaurus#{$.subType}";
        rr:termType rr:IRI;
		rr:class skos:ConceptScheme;
    ];
    .

<#SchemeFromDatasetAPI>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.task_categories_models_api.find({pipeline_tag:{$exists:true}})";
        rml:iterator "$.pipeline_tag.*";
    ];
    rr:subjectMap [ 
        rr:template "http://example.org/mluo/thesaurus#{$.subType}";
        rr:termType rr:IRI;
		rr:class skos:ConceptScheme;
    ];
    .

# ----------------------------------- Task Category

<#TaskCategory>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.tasks.find({}, {_id:0})";
        rml:iterator "$.*";
    ];
    rr:subjectMap [ 
        rr:template "http://example.org/mluo/thesaurus#{$.id}";
        rr:termType rr:IRI;
		rr:class mluo:TaskCategory;
		rr:class skos:Concept;
    ];
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel;
        rr:objectMap [ xrr:reference "$.label"; rr:language "en" ];
    ];
    rr:predicateObjectMap [
        rr:predicate skos:definition;
        rr:objectMap [ xrr:reference "$.summary"; rr:language "en" ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:source;
        rr:objectMap [ rr:constant "https://huggingface.co/api/tasks"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate skos:example;
        rr:objectMap [ rr:template "Dataset example: {$.datasets[0].description}."; rr:language "en" ];
    ];
    rr:predicateObjectMap [
        rr:predicate skos:example;
        rr:objectMap [ rr:template "Model example: {$.models[0].description}."; rr:language "en" ];
    ];
    rr:predicateObjectMap [
        rr:predicate skos:example;
        rr:objectMap [ rr:template "Demo example: {$.spaces[0].description}."; rr:language "en" ];
    ];
    rr:predicateObjectMap [
        rr:predicate skos:example;
        rr:objectMap [ rr:template "Library example: {$.libraries[0]}."; rr:language "en" ];
    ];
    .

<#TaskCategoryFromDatasetAPI>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.task_categories_api.find({task_categories:{$exists:true}})";
        rml:iterator "$.task_categories.*";
    ];
    rr:subjectMap [ 
        rr:template "http://example.org/mluo/thesaurus#{$.label}";
        rr:termType rr:IRI;
		rr:class mluo:TaskCategory;
		rr:class skos:Concept;
    ];
    rr:predicateObjectMap [
        rr:predicate skos:altLabel;
        rr:objectMap [ xrr:reference "$.label"; rr:termType rr:Literal ];
    ];
    rr:predicateObjectMap [
        rr:predicate skos:inScheme;
        rr:objectMap [ rr:template "http://example.org/mluo/thesaurus#{$.subType}"; rr:termType rr:IRI ];
    ];  
    rr:predicateObjectMap [
        rr:predicate skos:topConceptOf;
        rr:objectMap [ rr:template "http://example.org/mluo/thesaurus#{$.subType}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:source;
        rr:objectMap [ rr:constant "https://huggingface.co/api/tasks"; rr:termType rr:IRI ];
    ];
    .

<#TaskCategoryFromModelAPI>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.task_categories_models_api.find({pipeline_tag:{$exists:true}})";
        rml:iterator "$.pipeline_tag.*";
    ];
    rr:subjectMap [ 
        rr:template "http://example.org/mluo/thesaurus#{$.id}";
        rr:termType rr:IRI;
		rr:class mluo:TaskCategory;
		rr:class skos:Concept;
    ];
    # altLabel uniquement : tasks.json est la source maitre pour skos:prefLabel
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel;
        rr:objectMap [ xrr:reference "$.label"; rr:language "en" ];
    ];
    rr:predicateObjectMap [
        rr:predicate skos:inScheme;
        rr:objectMap [ rr:template "http://example.org/mluo/thesaurus#{$.subType}"; rr:termType rr:IRI ];
    ];  
    rr:predicateObjectMap [
        rr:predicate skos:topConceptOf;
        rr:objectMap [ rr:template "http://example.org/mluo/thesaurus#{$.subType}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:source;
        rr:objectMap [ rr:constant "https://huggingface.co/api/tasks"; rr:termType rr:IRI ];
    ];
    .


# ----------------------------------- Task Id


    <#TaskId>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.task_ids_api.find({task_ids:{$exists:true}})";
        rml:iterator "$.task_ids.*";
    ];
    rr:subjectMap [ 
        rr:template "http://example.org/mluo/thesaurus#{$.label}";
        rr:termType rr:IRI;
		rr:class mluo:Task;
		rr:class skos:Concept;
    ];
    rr:predicateObjectMap [
        rr:predicate skos:altLabel;
        rr:objectMap [ xrr:reference "$.id"; rr:language "en" ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:source;
        rr:objectMap [ rr:constant "https://huggingface.co/api/tasks"; rr:termType rr:IRI ];
    ];
    .