      skos:definition "Translation is the task of converting text from one language to another."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Translation"@en .

mluo_th:keypoint-detection
      a       mluo:TaskCategory , skos:Concept ;
