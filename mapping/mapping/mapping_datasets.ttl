@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix xrr: <http://i3s.unice.fr/xr2rml#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@prefix mluo: <http://example.org/mluo/ontology#> .
@prefix mluo_th: <http://example.org/mluo/thesaurus#> .

# Simplified mapping of preprocessed Hugging Face datasets.
# Expects collection documents preprocessed by preprocess_datasets.py:
# - normalized tags
# - task_ids[]
# - task_categories[]
# - modalities[]
# - languages[]
# - size_categories[]

<#Dataset>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#dataset/{$.dataset_hash16}";
        rr:termType rr:IRI;
        rr:class dcat:Dataset;
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:identifier;
        rr:objectMap [ xrr:reference "$.id" ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:description;
        rr:objectMap [ xrr:reference "$.description" ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:issued;
        rr:objectMap [ xrr:reference "$.created_at"; rr:datatype xsd:dateTime ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:modified;
        rr:objectMap [ xrr:reference "$.last_modified"; rr:datatype xsd:dateTime ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcat:landingPage;
        rr:objectMap [ rr:template "https://huggingface.co/datasets/{$.id}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcat:distribution;
        rr:objectMap [ rr:template "http://example.org/mluo/data#distribution/{$.distribution_hash16}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:publisher;
        rr:objectMap [ rr:constant "http://example.org/mluo/data#publisher/HuggingFace"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:spatial;
        rr:objectMap [ rr:constant "http://sws.geonames.org/6252001/"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate mluo:downloadCount;
        rr:objectMap [ xrr:reference "$.downloads"; rr:datatype xsd:integer ];
    ];
    rr:predicateObjectMap [
        rr:predicate mluo:likesCount;
        rr:objectMap [ xrr:reference "$.likes"; rr:datatype xsd:integer ];
    ];
    .

<#DatasetCreatorLink>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, author:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#dataset/{$.dataset_hash16}";
        rr:termType rr:IRI;
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:creator;
        rr:objectMap [ rr:template "http://example.org/mluo/data#creator/{$.creator_hash16}"; rr:termType rr:IRI ];
    ];
    .

<#DatasetAccessPublic>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, private:false, gated:false})";
    ];
    rr:subjectMap [ rr:template "http://example.org/mluo/data#dataset/{$.dataset_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate dcterms:accessRights; rr:objectMap [ rr:constant "public"; rr:termType rr:Literal ]; ];
    .

<#DatasetAccessRestricted>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, $or:[{private:true},{gated:true}]})";
    ];
    rr:subjectMap [ rr:template "http://example.org/mluo/data#dataset/{$.dataset_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate dcterms:accessRights; rr:objectMap [ rr:constant "restricted"; rr:termType rr:Literal ]; ];
    .

<#DatasetAvailabilityTrue>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, disabled:false})";
    ];
    rr:subjectMap [ rr:template "http://example.org/mluo/data#dataset/{$.dataset_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate mluo:availabilityStatus; rr:objectMap [ rr:constant "true"; rr:datatype xsd:boolean ]; ];
    rr:predicateObjectMap [ rr:predicate mluo:isAvailable; rr:objectMap [ rr:constant "true"; rr:datatype xsd:boolean ]; ];
    .

<#DatasetAvailabilityFalse>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, disabled:true})";
    ];
    rr:subjectMap [ rr:template "http://example.org/mluo/data#dataset/{$.dataset_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate mluo:availabilityStatus; rr:objectMap [ rr:constant "false"; rr:datatype xsd:boolean ]; ];
    rr:predicateObjectMap [ rr:predicate mluo:isAvailable; rr:objectMap [ rr:constant "false"; rr:datatype xsd:boolean ]; ];
    .

<#DatasetRawTag>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.datasets_subjects.find({dataset_hash16:{$exists:true}, subject:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [ rr:template "http://example.org/mluo/data#dataset/{$.dataset_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate dcterms:subject; rr:objectMap [ xrr:reference "$.subject"; rr:termType rr:Literal ]; ];
    .

<#DatasetTaskCategory>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.datasets_task_categories.find({dataset_hash16:{$exists:true}, task_category:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [ rr:template "http://example.org/mluo/data#dataset/{$.dataset_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [
        rr:predicate dcat:theme;
        rr:objectMap [ rr:template "http://example.org/mluo/thesaurus#{$.task_category}"; rr:termType rr:IRI ];
    ];
    .

