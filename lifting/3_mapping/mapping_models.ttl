@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix xrr: <http://i3s.unice.fr/xr2rml#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@prefix datalens_o:    <http://ns.inria.fr/datalens/ontology#> .
@prefix datalens_th:  <http://ns.inria.fr/datalens/thesaurus#> .

@prefix geonames: <http://sws.geonames.org/> .
@prefix lexvo: <https://lexvo.org/id/> .
@prefix iana: <https://www.iana.org/assignments/media-types/> .
@prefix spdx: <https://spdx.org/licenses/> .
@prefix cc: <http://creativecommons.org/licenses/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .

<#Model>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/datalens_o/data#model/{$.model_hash16}";
        rr:termType rr:IRI;
        rr:class datalens_o:Model;
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:identifier;
        rr:objectMap [ rr:template "{$.id}"];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:issued;
        rr:objectMap [ xrr:reference "$.created_at"; rr:datatype xsd:dateTime ];
    ];
    rr:predicateObjectMap [
        rr:predicate datalens_o:downloadCount;
        rr:objectMap [ xrr:reference "$.downloads"; rr:datatype xsd:integer ];
    ];
    rr:predicateObjectMap [
        rr:predicate datalens_o:likesCount;
        rr:objectMap [ xrr:reference "$.likes"; rr:datatype xsd:integer ];
    ];
    rr:predicateObjectMap [ 
        rr:predicate dcterms:subject; 
        rr:objectMap [ xrr:reference "$.tags[*]"; rr:termType rr:Literal ]; 
    ];


    # A relier à un thésaurus
    rr:predicateObjectMap [
        rr:predicate dcterms:spatial;
        rr:objectMap [ xrr:reference "$.region_uris[*]"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [ 
        rr:predicate dcterms:language; 
        rr:objectMap [ xrr:reference "$.language_uris[*]"; rr:termType rr:IRI ]; 
    ];
    rr:predicateObjectMap [
        rr:predicate datalens_o:hasLibrary;
        rr:objectMap [ rr:template "http://example.org/datalens_o/thesaurus#{$.libraries[*]}"; rr:termType rr:IRI ];
    ];

    # Tâches et modalités
    rr:predicateObjectMap [
        rr:predicate datalens_o:hasTaskCategory; 
        rr:objectMap [ rr:template "http://example.org/datalens_o/thesaurus#{$.task_categories[*]}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [ 
        rr:predicate datalens_o:hasModality; 
        rr:objectMap [ rr:template "http://example.org/datalens_o/thesaurus#{$.modalities[*]}"; rr:termType rr:IRI ]; 
    ];
    rr:predicateObjectMap [
        rr:predicate dcat:landingPage;
        rr:objectMap [ rr:template "https://huggingface.co/models/{$.id}"; rr:termType rr:IRI ];
    ];

    # Datasets et base models
    rr:predicateObjectMap [
        rr:predicate datalens_o:trainedOnDataset;
        rr:objectMap [ xrr:reference "$.datasets[*]"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate datalens_o:hasFineTunedBaseModel;
        rr:objectMap [ xrr:reference "$.finetuned_base_model"; rr:termType rr:IRI ];
    ];

    rr:predicateObjectMap [
        rr:predicate datalens_o:hasQuantizedBaseModel;
        rr:objectMap [ xrr:reference "$.quantized_base_model"; rr:termType rr:IRI ];
    ];

    rr:predicateObjectMap [
        rr:predicate datalens_o:hasMergedBaseModel;
        rr:objectMap [ xrr:reference "$.merged_base_model"; rr:termType rr:IRI ];
    ];

    rr:predicateObjectMap [
        rr:predicate datalens_o:hasAdapterBaseModel;
        rr:objectMap [ xrr:reference "$.adapter_base_model"; rr:termType rr:IRI ];
    ];

    # Liens vers d'autres ressources
    rr:predicateObjectMap [
        rr:predicate dcterms:creator;
        rr:objectMap [ rr:template "http://example.org/datalens_o/data#creator/{$.creator_hash16}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcat:distribution;
        rr:objectMap [ rr:template "http://example.org/datalens_o/data#distribution/{$.distribution_hash16}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:publisher;
        rr:objectMap [ rr:constant "http://example.org/datalens_o/data#publisher/HuggingFace"; rr:termType rr:IRI ];
    ];
    .

<#ModelHasAcademicArticle>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true,$ne:null}, article_hash16:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [ rr:template "http://example.org/datalens_o/data#model/{$.model_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [
        rr:predicate datalens_o:hasAcademicArticle;
        rr:objectMap [ rr:template "http://example.org/datalens_o/data#article/{$.article_hash16}"; rr:termType rr:IRI ];
    ];
    .

<#ModelAccessPublic>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, private:false, gated:false})";
    ];
    rr:subjectMap [ rr:template "http://example.org/datalens_o/data#model/{$.model_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate dcterms:accessRights; rr:objectMap [ rr:constant "public"; rr:termType rr:Literal ]; ];
    .

<#ModelAccessRestricted>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, $or:[{private:true},{gated:true}]})";
    ];
    rr:subjectMap [ rr:template "http://example.org/datalens_o/data#model/{$.model_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate dcterms:accessRights; rr:objectMap [ rr:constant "restricted"; rr:termType rr:Literal ]; ];
    .

<#ModelAvailabilityTrue>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, disabled:false})";
    ];
    rr:subjectMap [ rr:template "http://example.org/datalens_o/data#model/{$.model_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate datalens_o:isAvailable; rr:objectMap [ rr:constant "true"; rr:datatype xsd:boolean ]; ];
    .

<#ModelAvailabilityFalse>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, disabled:true})";
    ];
    rr:subjectMap [ rr:template "http://example.org/datalens_o/data#model/{$.model_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate datalens_o:isAvailable; rr:objectMap [ rr:constant "false"; rr:datatype xsd:boolean ]; ];
    .

<#AcademicArticle>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/datalens_o/data#article/{$.article_hash16}";
        rr:termType rr:IRI;
        rr:class datalens_o:AcademicArticle;
    ];
    rr:predicateObjectMap [ 
        rr:predicate datalens_o:paperswithcode_id; 
        rr:objectMap [ xrr:reference "$.paperswithcode_id" ]; 
    ];
    rr:predicateObjectMap [ 
        rr:predicate datalens_o:arxiv; 
        rr:objectMap [ xrr:reference "$.arxiv[*]" ]; 
    ];
    rr:predicateObjectMap [ 
        rr:predicate bibo:doi; 
        rr:objectMap [ xrr:reference "$.doi[*]" ]; 
    ];
    .

<#Distribution>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/datalens_o/data#distribution/{$.distribution_hash16}";
        rr:termType rr:IRI;
        rr:class dcat:Distribution;
    ];
    
    # A relier à un thésaurus
    rr:predicateObjectMap [
        rr:predicate dcterms:format;
        rr:objectMap [ xrr:reference "$.format_uris[*]"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:license;
        rr:objectMap [ xrr:reference "$.license_uris[*]"; rr:termType rr:IRI ];
    ];
    .

<#Creator>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, author:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/datalens_o/data#creator/{$.creator_hash16}";
        rr:termType rr:IRI;
        rr:class foaf:Agent;
    ];
    rr:predicateObjectMap [ rr:predicate foaf:name; rr:objectMap [ xrr:reference "$.author" ]; ];
    .

<#Publisher>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.findOne({id:{$exists:true}})";
    ];
    rr:subjectMap [
        rr:constant "http://example.org/datalens_o/data#publisher/HuggingFace";
        rr:termType rr:IRI;
        rr:class foaf:Organization;
    ];
    rr:predicateObjectMap [ rr:predicate foaf:name; rr:objectMap [ rr:constant "HuggingFace" ]; ];
    .

