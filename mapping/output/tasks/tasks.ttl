      skos:prefLabel "Audio"@en .

mluo_th:summarization
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Summarization is the task of producing a shorter version of a document while preserving its important information. Some models can extract text from the original input, while other models can generate entirely new text."@en ;
      skos:inScheme mluo_th:nlp ;
      skos:prefLabel "Summarization"@en ;
      skos:topConceptOf mluo_th:nlp .

mluo_th:image-text-to-image
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-text-to-image models take an image and a text prompt as input and generate a new image based on the reference image and text instructions. These models are useful for image editing, style transfer, image variations, and guided image generation tasks."@en ;
      skos:inScheme mluo_th:multimodal ;
      skos:prefLabel "Image Text-to-Image"@en ;
      skos:topConceptOf mluo_th:multimodal .

