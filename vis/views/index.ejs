<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>DataLens</title>

    <link rel="stylesheet" type="text/css" href="/datalens/css/main.css" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>

    <!-- Include the noUiSlider CSS and JS libraries -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/noUiSlider/14.7.0/nouislider.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/noUiSlider/14.7.0/nouislider.min.js"></script>

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/d3/5.16.0/d3.min.js" integrity="sha512-FHsFVKQ/T1KWJDGSbrUhTJyS1ph3eRrxI228ND0EGaEp6v4a/vGwPWd3Dtd/+9cI7ccofZvl/wulICEurHN1pg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    <script src="https://cdn.jsdelivr.net/npm/simple-statistics@7.8.3/dist/simple-statistics.min.js"></script>

    <script type="importmap">
        {
            "imports": {
                "@wimmics/venus-elements": "/datalens/node_modules/@wimmics/venus-elements/dist/index.js"
            }
        }
    </script>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">DataLens</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/datalens">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/datalens/explorer">Explorer</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container-fluid mt-4">
        <div class="card d-flex flex-column" style="height: 90vh;">
            <div class="card-header" id="viz-title">
                Dataset-task network from MLUO mapping
            </div>
            <div id="graph-info" class="px-3 py-2 border-bottom bg-light" style="font-size: 14px;">
                Loading graph summary...
            </div>
            <div class="card-body p-0" style="flex: 1 1 auto; min-height: 0;">
                <vis-graph id="venus-graph" width="100%" height="700" style="display: block; width: 100%; height: 100%; min-height: 500px;"></vis-graph>
                <div id="venus-error" class="text-danger p-3" style="display: none;"></div>
            </div>
        </div>
    </div>    
  

    <!-- Footer Section -->
  <footer class="bg-light text-center" style="height: 50px; display: flex; justify-content: center; align-items: center; gap: 15px;">
    <div style="display: flex; justify-content: center; align-items: center; gap: 10px;">
      <img src="/datalens/images/logos/uca.png" alt="UCA" style="height: 20px;">
      <img src="/datalens/images/logos/cnrs.png" alt="CNRS" style="height: 20px;">
      <img src="/datalens/images/logos/inria.png" alt="Inria" style="height: 20px;">
      <img src="/datalens/images/logos/i3s.png" alt="I3S" style="height: 20px;">
      <img src="/datalens/images/logos/wimmics.png" alt="Wimmics" style="height: 20px;">
    </div>
    <p style="margin: 0; padding-left: 15px; line-height: 40px; font-size: 12px;">&copy; 2024 DataLens. All rights reserved.</p>
  </footer>

</body>



<script type="module">
    import "@wimmics/venus-elements";

    const graph = document.querySelector("#venus-graph");
    const errorBox = document.querySelector("#venus-error");
    const infoBox = document.querySelector("#graph-info");
    const endpoint = `${window.location.origin}/datalens/venus-sparql`;

    if (!graph) {
        errorBox.style.display = "block";
        errorBox.textContent = "VisGraph element not found in DOM.";
        throw new Error("VisGraph element not found in DOM.");
    }

        graph.sparqlEndpoint = endpoint;
    graph.sparqlQuery = `PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX mluo: <http://example.org/mluo/ontology#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT
  ?datasetId
    ?task
FROM <http://example.org/data>
WHERE {
        ?dataset a dcat:Dataset ;
                         dcterms:identifier ?datasetId ;
                         mluo:hasTask ?task .
}
LIMIT 1500
`;
    graph.encoding = {
        "title": "Datasets connected by task",
        "nodes": {
            "field": ["datasetId", "task"],
        },
        "links": {
            "field": {
                "source": "datasetId",
                "target": "task"
            }
        },
        "interactions": { "nodeDetailsPanel": true }
    };

    async function loadGraphSummary() {
        const summaryQuery = `PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX mluo: <http://example.org/mluo/ontology#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT
  (COUNT(DISTINCT ?dataset) AS ?datasets)
  (COUNT(DISTINCT ?task) AS ?tasks)
  (COUNT(*) AS ?datasetTaskPairs)
  (ROUND(AVG(?downloadValue)) AS ?avgDownloads)
  (ROUND(AVG(?likesValue)) AS ?avgLikes)
FROM <http://example.org/data>
WHERE {
  ?dataset a dcat:Dataset ;
           mluo:hasTask ?task .

  OPTIONAL { ?dataset mluo:downloadCount ?downloads }
  OPTIONAL { ?dataset mluo:likesCount ?likes }

  BIND(IF(BOUND(?downloads), xsd:integer(?downloads), 0) AS ?downloadValue)
  BIND(IF(BOUND(?likes), xsd:integer(?likes), 0) AS ?likesValue)
}`;

        const summaryUrl = `${endpoint}?query=${encodeURIComponent(summaryQuery)}`;
        const response = await fetch(summaryUrl, {
            headers: { Accept: "application/sparql-results+json" }
        });

        if (!response.ok) {
            throw new Error(`Summary query failed: ${response.status} ${response.statusText}`);
        }

        const payload = await response.json();
        const row = payload?.results?.bindings?.[0];
        if (!row) {
            infoBox.textContent = "No summary available for current graph.";
            return;
        }

        const datasets = row.datasets?.value ?? "0";
        const tasks = row.tasks?.value ?? "0";
        const pairs = row.datasetTaskPairs?.value ?? "0";
        const avgDownloads = row.avgDownloads?.value ?? "0";
        const avgLikes = row.avgLikes?.value ?? "0";

        infoBox.innerHTML = `<strong>Summary:</strong> ${datasets} datasets, ${tasks} tasks, ${pairs} dataset-task links, avg downloads ${avgDownloads}, avg likes ${avgLikes}.`;
    }

    try {
        await loadGraphSummary();
        await graph.launch();
    } catch (error) {
        errorBox.style.display = "block";
        errorBox.textContent = `Venus launch error: ${error?.message || error}`;
        console.error("Venus launch error:", error);
    }
</script>

</html>