      skos:prefLabel "Voice Activity Detection"@en .

datalens_th:text-classification
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text Classification is the task of assigning a label or class to a given text. Some use cases are sentiment analysis, natural language inference, and assessing grammatical correctness."@en ;
      skos:example "Model example: A robust model trained for sentiment analysis."@en , "Dataset example: A widely used dataset used to benchmark multiple variants of text classification."@en , "Library example: adapter-transformers."@en , "Demo example: An application that can classify financial sentiment."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Text Classification"@en .

datalens_th:text-to-speech
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text-to-Speech (TTS) is the task of generating natural sounding speech given text input. TTS models can be extended to have a single model that generates speech for multiple speakers and multiple languages."@en ;
      skos:example "Model example: Small yet powerful TTS model."@en , "Dataset example: 10K hours of multi-speaker English dataset."@en , "Demo example: An application for generate high quality speech in different languages."@en , "Library example: espnet."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Text-to-Speech"@en .

datalens_th:text-to-image
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text-to-image is the task of generating images from input text. These pipelines can also be used to modify and edit images based on text prompts."@en ;
      skos:example "Library example: diffusers."@en , "Dataset example: RedCaps is a large-scale dataset of 12M image-text pairs collected from Reddit."@en , "Model example: One of the most powerful image generation models that can generate realistic outputs."@en , "Demo example: A powerful text-to-image application."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Text-to-Image"@en .

datalens_th:video-to-video
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Video-to-video models take one or more videos as input and generate new videos as output. They can enhance quality, interpolate frames, modify styles, or create new motion dynamics, enabling creative applications, video production, and research."@en ;
      skos:example "Dataset example: Dataset with detailed annotations for training and benchmarking video instance editing."@en , "Library example: diffusers."@en , "Model example: Model for editing outfits, character, and scenery in videos."@en , "Demo example: Interactive demo space for Lucy-Edit-Dev video editing."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Video-to-Video"@en .

datalens_th:text-ranking
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text Ranking is the task of ranking a set of texts based on their relevance to a query. Text ranking models are trained on large datasets of queries and relevant documents to learn how to rank documents based on their relevance to the query. This task is particularly useful for search engines and information retrieval systems."@en ;
      skos:example "Model example: An extremely efficient text ranking model trained on a web search dataset."@en , "Dataset example: Bing queries with relevant passages from various web sources."@en , "Library example: sentence-transformers."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Text Ranking"@en .

