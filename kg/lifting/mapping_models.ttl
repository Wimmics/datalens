<#Derivation>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true,$ne:null}})";
        rml:iterator "$.source_models[*]";
    ];
    rr:subjectMap [
        rr:template "http://[namespace]/datalens/data/derivation/{$.derivation_hash16}";
        rr:termType rr:IRI;
        rr:class prov:Derivation;
    ];
    rr:predicateObjectMap [
        rr:predicate prov:entity;
        rr:objectMap [ rr:template "http://[namespace]/datalens/data/model/{$.source_model_hash16[*]}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate prov:hadActivity;
        rr:objectMap [ rr:template "http://[namespace]/datalens/thesaurus/{$.transformation_type}"; rr:termType rr:IRI ];
    ];
    .

<#AcademicArticle>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://[namespace]/datalens/data/article/{$.article_hash16}";
        rr:termType rr:IRI;
        rr:class bibo:AcademicArticle;
    ];
    rr:predicateObjectMap [ 
        rr:predicate dcterms:identifier; 
        rr:objectMap [ xrr:reference "$.paperid[*]" ]; 
    ];
    rr:predicateObjectMap [ 
        rr:predicate bibo:doi; 
        rr:objectMap [ xrr:reference "$.doi[*]" ]; 
    ];
    rr:predicateObjectMap [ 
        rr:predicate dcterms:publisher; 
        rr:objectMap [ xrr:reference "$.paperurl[*]" ]; 
    ];
    .

<#Distribution>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://[namespace]/datalens/data/distribution/{$.distribution_hash16}";
        rr:termType rr:IRI;
        rr:class dcat:Distribution;
    ];

    rr:predicateObjectMap [
        rr:predicate dcterms:format;
        rr:objectMap [ rr:template "http://[namespace]/datalens/thesaurus/{$.formats[*]}"; rr:termType rr:IRI ];
    ];
    .

<#Creator>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, author:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://[namespace]/datalens/data/creator/{$.creator_hash16}";
        rr:termType rr:IRI;
        rr:class foaf:Agent;
    ];
    rr:predicateObjectMap [ 
        rr:predicate foaf:name; 
        rr:objectMap [ xrr:reference "$.author" ]; 
    ];
    .

<#Publisher>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.findOne({id:{$exists:true}})";
    ];
    rr:subjectMap [
        rr:constant "http://[namespace]/datalens/data/publisher/HuggingFace";
        rr:termType rr:IRI;
        rr:class foaf:Organization;
    ];
    rr:predicateObjectMap [ 
        rr:predicate foaf:name; 
        rr:objectMap [ rr:constant "HuggingFace"; rr:termType rr:Literal]; 
    ];
    .

