@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix xrr: <http://i3s.unice.fr/xr2rml#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix spdx: <https://spdx.org/licenses/> .
@prefix cc: <http://creativecommons.org/licenses/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix lexvo:   <https://lexvo.org/id/iso639-1/> .
@prefix lexvo3:  <https://lexvo.org/id/iso639-3/> .
@prefix iso3166: <https://www.iso.org/obp/ui/#iso:code:3166:> .
@prefix dlo:    <http://[namespace]/datalens/ontology/> .
@prefix dlt:  <http://[namespace]/datalens/thesaurus/> .

<#Model>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://[namespace]/datalens/data/model/{$.model_hash16}";
        rr:termType rr:IRI;
        rr:class dlo:Model;
        rr:class prov:Entity;
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:identifier;
        rr:objectMap [ xrr:reference "$.id"];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:issued;
        rr:objectMap [ xrr:reference "$.created_at"; rr:datatype xsd:dateTime ];
    ];
    rr:predicateObjectMap [
        rr:predicate dlo:downloadCount;
        rr:objectMap [ xrr:reference "$.downloads"; rr:datatype xsd:integer ];
    ];
    rr:predicateObjectMap [
        rr:predicate dlo:likesCount;
        rr:objectMap [ xrr:reference "$.likes"; rr:datatype xsd:integer ];
    ];
    rr:predicateObjectMap [ 
        rr:predicate dcat:keyword; 
        rr:objectMap [ xrr:reference "$.tags[*]"; rr:termType rr:Literal ]; 
    ];


    # Thésaurus externes
    rr:predicateObjectMap [
        rr:predicate dcterms:spatial;
        rr:objectMap [ xrr:reference "$.region_uris[*]"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [ 
        rr:predicate dcterms:language; 
        rr:objectMap [ xrr:reference "$.language_uris[*]"; rr:termType rr:IRI ]; 
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:license;
        rr:objectMap [ xrr:reference "$.license_uris[*]"; rr:termType rr:IRI ];
    ];


    # Intern thesaurus
    rr:predicateObjectMap [
        rr:predicate dlo:hasTask; 
        rr:objectMap [ rr:template "http://[namespace]/datalens/thesaurus/{$.task_categories[*]}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [ 
        rr:predicate dlo:hasModality; 
        rr:objectMap [ rr:template "http://[namespace]/datalens/thesaurus/{$.modalities[*]}"; rr:termType rr:IRI ]; 
    ];
    rr:predicateObjectMap [
        rr:predicate dlo:hasLibrary;
        rr:objectMap [ rr:template "http://[namespace]/datalens/thesaurus/{$.thesaurus_libraries[*]}"; rr:termType rr:IRI ];
    ];
    # Fallback in case the library is not in the thesaurus
    rr:predicateObjectMap [
        rr:predicate dlo:hasLibrary;
        rr:objectMap [ rr:template "http://[namespace]/datalens/data/library/{$.fallback_instances[*].library_hash16}"; rr:termType rr:IRI ];
    ];

    # Datasets et base models
    rr:predicateObjectMap [
        rr:predicate dlo:wasTrainedOn;
        rr:objectMap [ rr:template "http://[namespace]/datalens/data/dataset/{$.datasets_hash16[*]}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate prov:wasDerivedFrom;
        rr:objectMap [ rr:template "http://[namespace]/datalens/data/model/{$.source_models[*].source_model_hash16[*]}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate prov:qualifiedDerivation;
        rr:objectMap [ rr:template "http://[namespace]/datalens/data/derivation/{$.source_models[*].derivation_hash16}"; rr:termType rr:IRI ];
    ];

    rr:predicateObjectMap [
        rr:predicate dcat:landingPage;
        rr:objectMap [ rr:template "https://huggingface.co/{$.id}"; rr:termType rr:IRI ];
    ];

    # Liens vers d'autres ressources
    rr:predicateObjectMap [
        rr:predicate dcterms:creator;
        rr:objectMap [ rr:template "http://[namespace]/datalens/data/creator/{$.creator_hash16}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcat:distribution;
        rr:objectMap [ rr:template "http://[namespace]/datalens/data/distribution/{$.distribution_hash16}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dlo:hasAcademicArticle;
        rr:objectMap [ rr:template "http://[namespace]/datalens/data/article/{$.article_hash16}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:publisher;
        rr:objectMap [ rr:constant "http://[namespace]/datalens/data/publisher/HuggingFace"; rr:termType rr:IRI ];
    ];
    .

<#Library>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true,$ne:null}})";
        rml:iterator "$.fallback_instances[*]";
    ];
    rr:subjectMap [
        rr:template "http://[namespace]/datalens/data/library/{$.library_hash16}";
        rr:termType rr:IRI;
        rr:class dlo:Library;
    ];
    rr:predicateObjectMap [
        rr:predicate rdfs:label;
        rr:objectMap [ xrr:reference "$.library_label" ];
    ];
    .

<#ModelAccessPublic>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, private:false, gated:false})";
    ];
    rr:subjectMap [ rr:template "http://[namespace]/datalens/data/model/{$.model_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate dcterms:accessRights; rr:objectMap [ rr:constant "public"; rr:termType rr:Literal ]; ];
    .

<#ModelAccessRestricted>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, $or:[{private:true},{gated:true}]})";
    ];
    rr:subjectMap [ rr:template "http://[namespace]/datalens/data/model/{$.model_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate dcterms:accessRights; rr:objectMap [ rr:constant "restricted"; rr:termType rr:Literal ]; ];
    .

