      skos:example "Model example: Very powerful model that can translate many languages between each other, especially low-resource languages."@en , "Library example: transformers."@en , "Dataset example: A dataset of copyright-free books translated into 16 different languages."@en , "Demo example: An application that can translate between 100 languages."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Translation"@en .

