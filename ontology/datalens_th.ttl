@prefix schema:  <https://schema.org/> .
@prefix rr:      <http://www.w3.org/ns/r2rml#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rml:     <http://semweb.mmlab.be/ns/rml#> .
@prefix oa:      <http://www.w3.org/ns/oa#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix xrr:     <http://i3s.unice.fr/xr2rml#> .
@prefix bibo:    <http://purl.org/ontology/bibo/> .
@prefix dcat:    <http://www.w3.org/ns/dcat#> .

@prefix dlo:    <http://[namespace]/datalens/ontology/> .
@prefix dlt:  <http://[namespace]/datalens/thesaurus/> .



## Modality Scheme
dlt:ModalityScheme a skos:ConceptScheme ;
    skos:prefLabel "Dataset Modality Scheme"@en ;
    skos:definition "A controlled vocabulary for describing the data modality of datasets used in machine learning."@en ;
    skos:hasTopConcept 
        dlt:3D,
        dlt:Audio,
        dlt:Document,
        dlt:Geospatial,
        dlt:Image,
        dlt:Tabular,
        dlt:Text,
        dlt:TimeSeries,
        dlt:Video .

dlt:3D a skos:Concept, dlo:Modality ;
    skos:prefLabel "3D"@en ;
    skos:definition "Three-dimensional spatial data, such as point clouds or meshes."@en ;
    skos:inScheme dlt:ModalityScheme .

dlt:Audio a skos:Concept, dlo:Modality ;
    skos:prefLabel "Audio"@en ;
    skos:definition "Sound data, such as speech or environmental recordings."@en ;
    skos:inScheme dlt:ModalityScheme .

dlt:Document a skos:Concept, dlo:Modality ;
    skos:prefLabel "Document"@en ;
    skos:definition "Structured textual documents, such as PDFs or HTML pages."@en ;
    skos:inScheme dlt:ModalityScheme .

dlt:Geospatial a skos:Concept, dlo:Modality ;
    skos:prefLabel "Geospatial"@en ;
    skos:definition "Data with spatial/geographic components, such as GIS data."@en ;
    skos:inScheme dlt:ModalityScheme .

dlt:Image a skos:Concept, dlo:Modality ;
    skos:prefLabel "Image"@en ;
    skos:definition "Visual raster data, such as photographs or satellite imagery."@en ;
    skos:inScheme dlt:ModalityScheme .

dlt:Tabular a skos:Concept, dlo:Modality ;
    skos:prefLabel "Tabular"@en ;
    skos:definition "Structured data organized in rows and columns, such as spreadsheets or CSV files."@en ;
    skos:inScheme dlt:ModalityScheme .

dlt:Text a skos:Concept, dlo:Modality ;
    skos:prefLabel "Text"@en ;
    skos:definition "Unstructured or semi-structured plain text data."@en ;
    skos:inScheme dlt:ModalityScheme .

dlt:TimeSeries a skos:Concept, dlo:Modality ;
    skos:prefLabel "Time-series"@en ;
    skos:altLabel "Time series"@en ;
    skos:definition "Sequential data indexed by time, such as sensor readings or stock prices."@en ;
    skos:inScheme dlt:ModalityScheme .

dlt:Video a skos:Concept, dlo:Modality ;
    skos:prefLabel "Video"@en ;
    skos:definition "Temporal sequences of images, optionally with audio."@en ;
    skos:inScheme dlt:ModalityScheme .





## Transformation Scheme
dlt:TransformationScheme a skos:ConceptScheme ;
    skos:prefLabel "Transformation Scheme"@en ;
    skos:definition "A controlled vocabulary for describing the transformations applied to machine learning models."@en ;
    skos:hasTopConcept
            dlt:fineTune,
            dlt:Quantize,
            dlt:Merge,
            dlt:Adapt .

dlt:Finetune a dlo:Transformation ;
    skos:label "Fine-tune"@en ;
    skos:definition "A transformation where a pre-trained model is further trained on a specific task or dataset."@en ;
    skos:inScheme dlt:TransformationScheme .

dlt:Quantize a dlo:Transformation ;
    skos:label "Quantize"@en ;
    skos:definition "A transformation where a pre-trained model is quantized to reduce its size and improve inference speed."@en ;
    skos:inScheme dlt:TransformationScheme .

dlt:Merge a dlo:Transformation ;
    skos:label "Merge"@en ;
    skos:definition "A transformation where multiple pre-trained models are combined into a single model."@en ;
    skos:inScheme dlt:TransformationScheme .

dlt:Adapt a dlo:Transformation ;
    skos:label "Adapt"@en ;
    skos:definition "A transformation where a pre-trained model is adapted for a new task or domain."@en ;
    skos:inScheme dlt:TransformationScheme .    





## Format Scheme
dlt:FormatScheme
      a       skos:ConceptScheme ;
      skos:definition "A controlled vocabulary for describing the formats of dataset and model resources."@en ;
      skos:prefLabel "Dataset Format Scheme"@en .

dlt:WebDataset
      a       dlo:Format , skos:Concept ;
      skos:definition "A WebDataset file is a TAR archive containing a series of data files. WebDataset is designed for multimodal datasets, i.e. for image, audio and/or video datasets."@en ;
      skos:seeAlso <https://huggingface.co/docs/hub/en/datasets-webdataset> ;
      skos:inScheme dlt:FormatScheme ;
      skos:prefLabel "Web Dataset"@en .

dlt:ImageFolder
      a       dlo:Format , skos:Concept ;
      skos:definition "A folder-based organization where image files are grouped in directories."@en ;
      skos:inScheme dlt:FormatScheme ;
      skos:prefLabel "Image Folder"@en .

dlt:AudioFolder
      a       dlo:Format , skos:Concept ;
      skos:definition "A folder-based organization where audio files are grouped in directories."@en ;
      skos:inScheme dlt:FormatScheme ;
      skos:prefLabel "Audio Folder"@en .

dlt:AgentTraces
      a       dlo:Format , skos:Concept ;
      skos:definition "A trace-oriented format used to store execution logs and interaction traces for AI agents."@en ;
      skos:seeAlso <https://huggingface.co/changelog/agent-trace-viewer> ;
      skos:inScheme dlt:FormatScheme ;
      skos:prefLabel "Traces"@en .

dlt:Arrow
      a       dlo:Format , skos:Concept ;
      skos:definition "Apache Arrow defines a language-independent columnar memory format for flat and nested data, organized for efficient analytic operations on modern hardware like CPUs and GPUs."@en ;
      skos:exactMatch <https://www.iana.org/assignments/media-types/application/vnd.apache.arrow.file> ;
      skos:seeAlso <https://arrow.apache.org/> ;
      skos:inScheme dlt:FormatScheme ;
      skos:prefLabel "Apache Arrow"@en .

dlt:CSV
      a       dlo:Format , skos:Concept ;
      skos:definition "Comma-separated values (CSV) is a plain text data format for storing tabular data where the fields of a record are separated by a comma and each record is a line."@en ;
      skos:exactMatch <https://www.iana.org/assignments/media-types/text/csv> ;
      skos:seeAlso <https://en.wikipedia.org/wiki/Comma-separated_values> ;
      skos:inScheme dlt:FormatScheme ;
      skos:prefLabel "CSV"@en .

dlt:JSON
      a       dlo:Format , skos:Concept ;
      skos:definition "JSON (JavaScript Object Notation) is an open standard file format and data interchange format that uses human-readable text to store and transmit data objects consisting of name–value pairs and arrays."@en ;
      skos:exactMatch <https://www.iana.org/assignments/media-types/application/json> ;
      skos:seeAlso <https://json.org/>, <https://en.wikipedia.org/wiki/JSON>;
      skos:inScheme dlt:FormatScheme ;
      skos:prefLabel "JSON"@en .

dlt:Parquet
      a       dlo:Format , skos:Concept ;
      skos:definition "Apache Parquet is an open source, column-oriented data file format designed for efficient data storage and retrieval."@en ;
      skos:exactMatch <https://www.iana.org/assignments/media-types/application/vnd.apache.parquet> ;
      skos:seeAlso <https://parquet.apache.org/> ;
      skos:inScheme dlt:FormatScheme ;
      skos:prefLabel "Apache Parquet"@en .

dlt:OptimizedParquet
      a       dlo:Format , skos:Concept ;
      skos:definition "Optimized Parquet is Hugging Face’s enhanced version of the standard Parquet columnar-storage format. It utilizes Content-Defined Chunking (CDC), which allows for faster deduped uploads and downloads of datasets."@en ;
      skos:closeMatch <https://www.iana.org/assignments/media-types/application/vnd.apache.parquet> ;
      skos:seeAlso <https://huggingface.co/docs/hub/en/datasets-optimized-parquet>, <https://parquet.apache.org/>, <https://huggingface.co/docs/xet/chunking> ;
      skos:inScheme dlt:FormatScheme ;
      skos:prefLabel "Optimized Apache Parquet"@en ;
      skos:related dlt:Parquet .

dlt:Text
      a       dlo:Format , skos:Concept ;
      skos:definition "A text file is a kind of computer file that is structured as a sequence of lines of electronic text."@en ;
      skos:exactMatch <https://www.iana.org/assignments/media-types/text/plain> ;
      skos:seeAlso <https://en.wikipedia.org/wiki/Text_file> ;
      skos:inScheme dlt:FormatScheme ;
      skos:prefLabel "Text"@en .





## Dataset Size Scheme
dlt:DatasetSizeScheme
      a       skos:ConceptScheme ;
      skos:definition "A controlled vocabulary for describing the size of a dataset, according to HuggingFace definition."@en ;
      skos:prefLabel "Dataset Size Scheme"@en .

dlt:1
      a       dlo:SizeCategory , skos:Concept ;
      skos:inScheme dlt:DatasetSizeScheme ;
      skos:prefLabel "< 1K"@en ;
      skos:definition "Less than 1,000 records"@en .

dlt:1k
      a       dlo:SizeCategory , skos:Concept ;
      skos:inScheme dlt:DatasetSizeScheme ;
      skos:prefLabel "1K - 10K"@en ;
      skos:definition "Between 1,000 and 10,000 records"@en .

dlt:10k
      a       dlo:SizeCategory , skos:Concept ;
      skos:inScheme dlt:DatasetSizeScheme ;
      skos:prefLabel "10K - 100K"@en ;
      skos:definition "Between 10,000 and 100,000 records"@en .

dlt:100k
      a       dlo:SizeCategory , skos:Concept ;
      skos:inScheme dlt:DatasetSizeScheme ;
      skos:prefLabel "100K - 1M"@en ;
      skos:definition "Between 100,000 and 1,000,000 records"@en .

dlt:1m
      a       dlo:SizeCategory , skos:Concept ;
      skos:inScheme dlt:DatasetSizeScheme ;
      skos:prefLabel "1M - 10M"@en ;
      skos:definition "Between 1,000,000 and 10,000,000 records"@en .

dlt:10m
      a       dlo:SizeCategory , skos:Concept ;
      skos:inScheme dlt:DatasetSizeScheme ;
      skos:prefLabel "10M - 100M"@en ;
      skos:definition "Between 10,000,000 and 100,000,000 records"@en .

dlt:100m
      a       dlo:SizeCategory , skos:Concept ;
      skos:inScheme dlt:DatasetSizeScheme ;
      skos:prefLabel "100M - 1B"@en ;
      skos:definition "Between 100,000,000 and 1,000,000,000 records"@en .

dlt:1b
      a       dlo:SizeCategory , skos:Concept ;
      skos:inScheme dlt:DatasetSizeScheme ;
      skos:prefLabel "1B - 10B"@en ;
      skos:definition "Between 1,000,000,000 and 10,000,000,000 records"@en .

dlt:10b
      a       dlo:SizeCategory , skos:Concept ;
      skos:inScheme dlt:DatasetSizeScheme ;
      skos:prefLabel "10B - 100B"@en ;
      skos:definition "Between 10,000,000,000 and 100,000,000,000 records"@en .

dlt:100b
      a       dlo:SizeCategory , skos:Concept ;
      skos:inScheme dlt:DatasetSizeScheme ;
      skos:prefLabel "100B - 1T"@en ;
      skos:definition "Between 100,000,000,000 and 1,000,000,000,000 records"@en .

dlt:1t
      a       dlo:SizeCategory , skos:Concept ;
      skos:inScheme dlt:DatasetSizeScheme ;
      skos:prefLabel "> 1T"@en ;
      skos:definition "More than 1,000,000,000,000 records"@en .





## Dataset Library Scheme
dlt:DatasetLibraryScheme
      a       skos:ConceptScheme ;
      skos:definition "A controlled vocabulary for describing the libraries of dataset resources."@en ;
      skos:prefLabel "Dataset Library Scheme"@en .

dlt:DataDesigner
      a       skos:Concept , dlo:Library ;
      skos:seeAlso <https://huggingface.co/docs/hub/en/datasets-data-designer>, <https://nvidia-nemo.github.io/DataDesigner/latest/> ;
      skos:definition "Data Designer is NVIDIA NeMo’s framework for generating high-quality synthetic datasets using LLMs. It enables you to create diverse data using statistical samplers, LLMs, or existing seed datasets."@en ;
      skos:inScheme dlt:DatasetLibraryScheme ;
      skos:prefLabel "NeMo Data Designer"@en .

dlt:Lance
      a       skos:Concept , dlo:Library ;
      skos:seeAlso <https://huggingface.co/docs/hub/en/datasets-lance>, <https://lance.org/> ;
      skos:definition "Lance is an open multimodal lakehouse table format for AI."@en ;
      skos:inScheme dlt:DatasetLibraryScheme ;
      skos:prefLabel "Lance"@en .

dlt:Datasets
      a       skos:Concept , dlo:Library ;
      skos:seeAlso <https://huggingface.co/docs/datasets/index>, <https://pypi.org/project/datasets/> ;
      skos:definition "Datasets is a library for easily accessing and sharing AI datasets for Audio, Computer Vision, and Natural Language Processing (NLP) tasks."@en ;
      skos:inScheme dlt:DatasetLibraryScheme ;
      skos:prefLabel "Datasets"@en .

dlt:WebDataset
      a       skos:Concept , dlo:Library ;
      skos:seeAlso <https://huggingface.co/docs/hub/en/datasets-webdataset>, <https://pypi.org/project/webdataset/> ;
      skos:definition "WebDataset is a library for writing I/O pipelines for large datasets. Its sequential I/O and sharding features make it especially useful for streaming large-scale datasets to a DataLoader."@en ;
      skos:inScheme dlt:DatasetLibraryScheme ;
      skos:prefLabel "WebDataset"@en .

dlt:Polars
      a       skos:Concept , dlo:Library ;
      skos:seeAlso <https://huggingface.co/docs/hub/en/datasets-polars>, <https://pola.rs/> ;
      skos:definition "Polars is an in-memory DataFrame library on top of an OLAP query engine."@en ;
      skos:inScheme dlt:DatasetLibraryScheme ;
      skos:prefLabel "Polars"@en .

dlt:Dask
      a       skos:Concept , dlo:Library ;
      skos:seeAlso <https://huggingface.co/docs/hub/en/datasets-dask>, <https://www.dask.org/> ;
      skos:definition "Dask is a parallel and distributed computing library that scales the existing Python and PyData ecosystem."@en ;
      skos:inScheme dlt:DatasetLibraryScheme ;
      skos:prefLabel "Dask"@en .

dlt:Pandas
      a       skos:Concept , dlo:Library ;
      skos:seeAlso <https://huggingface.co/docs/hub/en/datasets-pandas>, <https://pandas.pydata.org/> ;
      skos:definition "Pandas is a widely used Python data analysis toolkit."@en ;
      skos:inScheme dlt:DatasetLibraryScheme ;
      skos:prefLabel "pandas"@en .

dlt:FiftyOne
      a       skos:Concept , dlo:Library ;
      skos:seeAlso <https://huggingface.co/docs/hub/en/datasets-fiftyone>, <https://docs.voxel51.com/> ;
      skos:definition "FiftyOne is an open-source toolkit for curating, visualizing, and managing unstructured visual data."@en ;
      skos:inScheme dlt:DatasetLibraryScheme ;
      skos:prefLabel "FiftyOne"@en .

dlt:Distilabel
      a       skos:Concept , dlo:Library ;
      skos:seeAlso <https://huggingface.co/docs/hub/en/datasets-distilabel>, <https://distilabel.argilla.io/1.1.1/> ;
      skos:definition "Distilabel is a framework for synthetic data and AI feedback for engineers who need fast, reliable and scalable pipelines based on verified research papers."@en ;
      skos:inScheme dlt:DatasetLibraryScheme ;
      skos:prefLabel "Distilabel"@en .

dlt:MLCroissant
      a       skos:Concept , dlo:Library ;
      skos:seeAlso <https://huggingface.co/docs/dataset-viewer/en/mlcroissant>, <https://pypi.org/project/mlcroissant/> ;
      skos:definition "mlcroissant is a library to load datasets from Croissant metadata."@en ;
      skos:inScheme dlt:DatasetLibraryScheme ;
      skos:prefLabel "Croissant"@en .

dlt:Argilla
      a       skos:Concept , dlo:Library ;
      skos:seeAlso <https://huggingface.co/docs/hub/en/datasets-argilla>, <https://docs.argilla.io/latest/> ;
      skos:definition "Argilla is a collaboration tool for AI engineers and domain experts who need to build high quality datasets for their projects."@en ;
      skos:inScheme dlt:DatasetLibraryScheme ;
      skos:prefLabel "Argilla"@en .





## Model Library Scheme
dlt:ModelLibraryScheme
      a       skos:ConceptScheme ;
      skos:definition "A controlled vocabulary for describing the libraries of machine learning models."@en ;
      skos:prefLabel "Model Library Scheme"@en .

dlt:Pytorch
      a       skos:Concept , dlo:Library ;
      skos:definition "PyTorch is an optimized tensor library for deep learning using GPUs and CPUs."@en ;
      skos:seeAlso <https://pytorch.org/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "PyTorch"@en .

dlt:Sklearn
      a       skos:Concept , dlo:Library ;
      skos:definition "Scikit-learn is an open source machine learning library that supports supervised and unsupervised learning. It also provides various tools for model fitting, data preprocessing, model selection, model evaluation, and many other utilities."@en ;
      skos:seeAlso <https://scikit-learn.org/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Scikit-learn"@en .

dlt:TransformersJS
      a       skos:Concept , dlo:Library ;
      skos:definition "Transformers.js is a JavaScript library for the Hugging Face Transformers library."@en ;
      skos:seeAlso <https://huggingface.co/docs/transformers.js/> ;
      skos:relate dlt:Transformers ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Transformers.js"@en .

dlt:Transformers
      a       skos:Concept , dlo:Library ;
      skos:definition "Transformer is a library maintained by Hugging Face and its community, for state-of-the-art Machine Learning for Pytorch, TensorFlow and JAX."@en ;
      skos:seeAlso <https://huggingface.co/docs/transformers/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Transformers"@en .

dlt:Allennlp
      a       skos:Concept , dlo:Library ;
      skos:definition "AllenNLP is an Apache 2.0 NLP research library, built on PyTorch, for developing state-of-the-art deep learning models on a wide variety of linguistic tasks."@en ;
      skos:seeAlso <https://docs.allennlp.org/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "AllenNLP"@en .

dlt:Stanza
      a       skos:Concept , dlo:Library ;
      skos:definition "Stanza is a Python natural language analysis package. It provides a collection of tools for the linguistic analysis of many human languages."@en ;
      skos:seeAlso <https://stanfordnlp.github.io/stanza/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Stanza"@en .

dlt:PaddleOCR
      a       skos:Concept , dlo:Library ;
      skos:definition "PaddleOCR is an OCR tool developed by PaddlePaddle, it converts PDF documents and images into structured, LLM-ready data (JSON/Markdown)."@en ;
      skos:seeAlso <https://www.paddleocr.ai/latest/en/index.html> ;
      skos:relate dlt:Paddlepaddle ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "PaddleOCR"@en .

dlt:AdapterTransformers
      a       skos:Concept , dlo:Library ;
      skos:definition "Adapters is an add-on library to Hugging Face Transformers for efficiently fine-tuning pre-trained language models using adapters and other parameter-efficient methods."@en ;
      skos:seeAlso <https://docs.adapterhub.ml/> ;
      skos:relate dlt:Transformers ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Adapters"@en .

dlt:Rust
      a       skos:Concept , dlo:Library ;
      skos:definition "Rust is a fast, memory-safe, and productive programming language that can run on embedded devices, web services, and more."@en ;
      skos:seeAlso <https://www.rust-lang.org/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Rust"@en .

dlt:KerasHub
      a       skos:Concept , dlo:Library ;
      skos:definition "KerasHub is a pretrained modeling library that aims to be simple, flexible, and fast."@en ;
      skos:seeAlso <https://keras.io/keras_hub/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "KerasHub"@en .

dlt:SentenceTransformers
      a       skos:Concept , dlo:Library ;
      skos:definition "Sentence Transformers is a Python module for using and training state-of-the-art embedding and reranker models."@en ;
      skos:seeAlso <https://www.sbert.net/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Sentence Transformers"@en .

dlt:Speechbrain
      a       skos:Concept , dlo:Library ;
      skos:definition "SpeechBrain is an open-source and all-in-one speech toolkit based on PyTorch."@en ;
      skos:seeAlso <https://speechbrain.readthedocs.io/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "SpeechBrain"@en .

dlt:LiteRT
      a       skos:Concept , dlo:Library ;
      skos:definition "LiteRT, successor to TensorFlow Lite, is Google's On-device framework for high-performance ML & GenAI deployment on edge platforms, via efficient conversion, runtime, and optimization"@en ;
      skos:seeAlso <https://ai.google.dev/edge/litert> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "LiteRT"@en .

dlt:Espnet
      a       skos:Concept , dlo:Library ;
      skos:definition "ESPnet is an end-to-end toolkit for speech processing, including automatic speech recognition, text to speech, speech enhancement, dirarization and other tasks."@en ;
      skos:seeAlso <https://espnet.github.io/espnet/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "ESPnet"@en .

dlt:PyannoteAudio
      a       skos:Concept , dlo:Library ;
      skos:definition "PyAnnote.audio is an open-source toolkit written in Python for speaker diarization."@en ;
      skos:seeAlso <https://docs.pyannote.ai/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "PyAnnote.audio"@en .

dlt:OpenClip
      a       skos:Concept , dlo:Library ;
      skos:definition "OpenCLIP is an open-source implementation of OpenAI’s CLIP."@en ;
      skos:seeAlso <https://huggingface.co/docs/hub/open_clip> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "OpenCLIP"@en .

dlt:Peft
      a       skos:Concept , dlo:Library ;
      skos:definition "PEFT (Parameter-Efficient Fine-Tuning) is a library for efficiently adapting large pretrained models to various downstream applications without fine-tuning all of a model’s parameters because it is prohibitively costly."@en ;
      skos:seeAlso <https://huggingface.co/docs/peft/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "PEFT"@en .

dlt:Fasttext
      a       skos:Concept , dlo:Library ;
      skos:definition "FastText is an open-source, free, lightweight library that allows users to learn text representations and text classifiers."@en ;
      skos:seeAlso <https://fasttext.cc/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "FastText"@en .

dlt:Tensorboard
      a       skos:Concept , dlo:Library ;
      skos:definition "TensorBoard provides tooling for tracking and visualizing metrics as well as visualizing models."@en ;
      skos:seeAlso <https://www.tensorflow.org/tensorboard> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "TensorBoard"@en .

dlt:Keras
      a       skos:Concept , dlo:Library ;
      skos:definition "Keras is an open-source multi-backend deep learning framework, with support for JAX, TensorFlow, and PyTorch."@en ;
      skos:seeAlso <https://keras.io/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Keras"@en .

dlt:StableBaselines3
      a       skos:Concept , dlo:Library ;
      skos:definition "Stable Baselines3 is a set of reliable implementations of reinforcement learning algorithms in PyTorch."@en ;
      skos:seeAlso <https://stable-baselines3.readthedocs.io/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Stable Baselines3"@en .

dlt:Nemo
      a       skos:Concept , dlo:Library ;
      skos:definition "NVIDIA NeMo Framework is a scalable and cloud-native generative AI framework built for researchers and developers working on Large Language Models, Multimodal, and Speech AI."@en ;
      skos:seeAlso <https://docs.nvidia.com/nemo-framework/user-guide/latest/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "NeMo"@en .

dlt:Asteroid
      a       skos:Concept , dlo:Library ;
      skos:definition "Asteroid is a Pytorch-based audio source separation toolkit that enables fast experimentation on common datasets."@en ;
      skos:seeAlso <https://asteroid-team.github.io/asteroid/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Asteroid"@en .

dlt:OptimumGraphcore
      a       skos:Concept , dlo:Library ;
      skos:definition "Optimum Graphcore is the interface between the Hugging Face Transformers library and Graphcore IPUs. It provides a set of tools enabling model parallelization and loading on IPUs, training and fine-tuning on all the tasks already supported by Transformers."@en ;
      skos:seeAlso <https://huggingface.co/docs/optimum/graphcore/index> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Graphcore"@en .

dlt:TFKeras
      a       skos:Concept , dlo:Library ;
      skos:definition "tf-keras is the name given to Keras 2.x version."@en ;
      skos:seeAlso <https://huggingface.co/docs/hub/tf-keras> ;
      skos:relate dlt:Keras ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "TF-Keras"@en .

dlt:SpanMarker
      a       skos:Concept , dlo:Library ;
      skos:definition "SpanMarker is a framework for training powerful Named Entity Recognition models using familiar encoders such as BERT, RoBERTa and ELECTRA."@en ;
      skos:seeAlso <https://tomaarsen.github.io/SpanMarkerNER/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "SpanMarker"@en .

dlt:PaddleNLP
      a       skos:Concept , dlo:Library ;
      skos:definition "Leveraging the PaddlePaddle framework, PaddleNLP is a NLP library with pre-trained model zoo, supporting wide-range of NLP tasks from research to industrial applications."@en ;
      skos:seeAlso <https://paddlenlp.readthedocs.io/en/latest/> ;
      skos:relate dlt:Paddlepaddle ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "PaddleNLP"@en .

dlt:Joblib
      a       skos:Concept , dlo:Library ;
      skos:definition "Joblib is a set of tools to provide lightweight pipelining in Python."@en ;
      skos:seeAlso <https://joblib.readthedocs.io/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Joblib"@en .

dlt:OptimumHabana
      a       skos:Concept , dlo:Library ;
      skos:definition "Optimum for Intel Gaudi (optimum-habana) is the interface between the Transformers and Diffusers libraries and Intel Gaudi AI Accelerators (HPU). It provides a set of tools enabling easy model loading, training and inference on single and multi-HPU settings for different downstream tasks."@en ;
      skos:seeAlso <https://huggingface.co/docs/optimum-habana/index> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Habana"@en .

dlt:Univa
      a       skos:Concept , dlo:Library ;
      skos:definition "UniVA (Universal Video Agent) is an open-source, next-generation video generalist system that enables planning, composing, and producing videos through natural language instructions."@en ;
      skos:seeAlso <https://github.com/univa-agent/univa> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "UniVA"@en .

dlt:DDUF
      a       skos:Concept , dlo:Library ;
      skos:definition "DDUF (DDUF’s Diffusion Unified Format) is a single-file format for diffusion models that aims to unify the different model distribution methods and weight-saving formats by packaging all model components into a single file."@en ;
      skos:seeAlso <https://huggingface.co/docs/hub/en/dduf> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "DDUF"@en .

dlt:OpenVINO
      a       skos:Concept , dlo:Library ;
      skos:definition "OpenVINO is an open-source toolkit for optimizing and deploying AI inference."@en ;
      skos:seeAlso <https://docs.openvino.ai/2026/index.html> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "OpenVINO"@en .

dlt:GGUF
      a       skos:Concept , dlo:Library ;
      skos:definition "GGUF is a binary format that is designed for fast loading and saving of models, and for ease of reading"@en ;
      skos:seeAlso <https://github.com/ggml-org/ggml/blob/master/docs/gguf.md> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "GGUF"@en .

dlt:Flair
      a       skos:Concept , dlo:Library ;
      skos:definition "Flair is a simple framework for state-of-the-art NLP."@en ;
      skos:seeAlso <https://flairnlp.github.io/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Flair"@en .

dlt:CoreML
      a       skos:Concept , dlo:Library ;
      skos:definition "Core ML is a framework for integrating machine learning models into Apple applications."@en ;
      skos:seeAlso <https://developer.apple.com/documentation/coreml> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Core ML"@en .

dlt:SetFit
      a       skos:Concept , dlo:Library ;
      skos:definition " SetFit is a prompt-free framework for few-shot fine-tuning of Sentence Transformers."@en ;
      skos:seeAlso <https://huggingface.co/docs/setfit/> ;
      skos:relate dlt:SentenceTransformers ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "SetFit"@en .

dlt:ONNX
      a       skos:Concept , dlo:Library ;
      skos:definition "ONNX (Open Neural Network Exchange) is an open format built to represent machine learning models."@en ;
      skos:seeAlso <https://onnx.ai/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "ONNX"@en .

dlt:Jax
      a       skos:Concept , dlo:Library ;
      skos:definition "JAX is a Python library for accelerator-oriented array computation and program transformation, designed for high-performance numerical computing and large-scale machine learning."@en ;
      skos:seeAlso <https://docs.jax.dev/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "JAX"@en .

dlt:Spacy
      a       skos:Concept , dlo:Library ;
      skos:definition "spaCy is an open-source library for advanced natural language processing in Python."@en ;
      skos:seeAlso <https://spacy.io/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "spaCy"@en .

dlt:Diffusers
      a       skos:Concept , dlo:Library ;
      skos:definition "Diffusers is a library of state-of-the-art pretrained diffusion models for generating videos, images, and audio."@en ;
      skos:seeAlso <https://huggingface.co/docs/diffusers/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Diffusers"@en .

dlt:LlamaFile
      a       skos:Concept , dlo:Library ;
      skos:definition "llamafile is a Mozilla Builders project that enables users to distribute and run LLMs with a single file."@en ;
      skos:seeAlso <https://docs.mozilla.ai/llamafile> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "LlamaFile"@en .

dlt:SampleFactory
      a       skos:Concept , dlo:Library ;
      skos:definition "sample-factory is a codebase for high throughput asynchronous reinforcement learning."@en ;
      skos:seeAlso <https://www.samplefactory.dev/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Sample Factory"@en .

dlt:Fairseq
      a       skos:Concept , dlo:Library ;
      skos:definition "Fairseq is a sequence modeling toolkit that allows researchers and developers to train custom models for translation, summarization, language modeling, and other text generation tasks."@en ;
      skos:seeAlso <https://fairseq.readthedocs.io/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Fairseq"@en .

dlt:Timm
      a       skos:Concept , dlo:Library ;
      skos:definition "timm is a deep-learning library created by Ross Wightman and is a collection of SOTA computer vision models, layers, utilities, optimizers, schedulers, data-loaders, augmentations and also training/validating scripts with ability to reproduce ImageNet training results."@en ;
      skos:seeAlso <https://timm.fast.ai/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "timm"@en .

dlt:PaddlePaddle
      a       skos:Concept , dlo:Library ;
      skos:definition "PaddlePaddle, short for PArallel Distributed Deep LEarning, is an open-source deep learning platform developed by Baidu."@en ;
      skos:seeAlso <https://www.paddlepaddle.org.cn/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "PaddlePaddle"@en .

dlt:MLAgents
      a       skos:Concept , dlo:Library ;
      skos:definition "The Unity Machine Learning Agents Toolkit (ML-Agents Toolkit) is an open-source project that enables games and simulations to serve as environments for training intelligent agents."@en ;
      skos:seeAlso <https://docs.unity3d.com/Packages/com.unity.ml-agents@4.0/manual/index.html> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "ML Agents"@en .

dlt:FastAI
      a       skos:Concept , dlo:Library ;
      skos:definition "fastai is an open-source Deep Learning library that leverages PyTorch and Python to provide high-level components to train fast and accurate neural networks with state-of-the-art outputs on text, vision, and tabular data."@en ;
      skos:seeAlso <https://docs.fast.ai/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "fastai"@en .

dlt:ExecuTorch
      a       skos:Concept , dlo:Library ;
      skos:definition "ExecuTorch is PyTorch’s solution for training and inference on the Edge, providing portability, productivity, and performance for edge computing platforms."@en ;
      skos:seeAlso <https://docs.pytorch.org/executorch/stable/index.html> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "ExecuTorch"@en .

dlt:TF
      a       skos:Concept , dlo:Library ;
      skos:definition "TensorFlow is an end-to-end open source platform for machine learning, developed by Google."@en ;
      skos:seeAlso <https://www.tensorflow.org/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "TensorFlow"@en .

dlt:MLX
      a       skos:Concept , dlo:Library ;
      skos:definition "MLX is a NumPy-like array framework designed for efficient and flexible machine learning on Apple silicon, by Apple machine learning research."@en ;
      skos:seeAlso <https://ml-explore.github.io/mlx> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "MLX"@en .

dlt:UnitySentis
      a       skos:Concept , dlo:Library ;
      skos:definition "Sentis is a neural network inference library for Unity."@en ;
      skos:seeAlso <https://docs.unity3d.com/Packages/com.unity.sentis@2.1/manual/index.html> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "unity-sentis"@en .

dlt:Safetensors
      a       skos:Concept , dlo:Library ;
      skos:definition "Safetensors is a new simple format for storing tensors safely (as opposed to pickle) and that is still fast (zero-copy)."@en ;
      skos:seeAlso <https://huggingface.co/docs/safetensors/index> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "Safetensors"@en .

dlt:BERTopic
      a       skos:Concept , dlo:Library ;
      skos:definition "BERTopic is a topic modeling framework that leverages Hugging Face transformers and c-TF-IDF to create dense clusters allowing for easily interpretable topics whilst keeping important words in the topic descriptions."@en ;
      skos:seeAlso <https://maartengr.github.io/BERTopic/> ;
      skos:inScheme dlt:ModelLibraryScheme ;
      skos:prefLabel "BERTopic"@en .





## Task Scheme
dlt:TaskScheme
      a       skos:ConceptScheme ;
      skos:definition "A controlled vocabulary for describing machine learning tasks."@en ;
      skos:prefLabel "Machine Learning Task Scheme"@en .

# ----------------------------------- Collections

dlt:RL
      a       skos:Collection ;
      skos:member dlt:Robotics , dlt:ReinforcementLearning ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Reinforcement Learning"@en .

dlt:NLP
      a       skos:Collection ;
      skos:member dlt:FillMask , dlt:Summarization , dlt:QuestionAnswering , dlt:TokenClassification , dlt:SentenceSimilarity , dlt:Translation , dlt:ZeroShotClassification , dlt:TextClassification , dlt:TextRetrieval , dlt:TextGeneration , dlt:FeatureExtraction , dlt:MultipleChoice , dlt:TableToText , dlt:TableQuestionAnswering , dlt:TextRanking ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Natural Language Processing"@en .

dlt:Tabular
      a       skos:Collection ;
      skos:member dlt:TabularToText , dlt:TabularRegression , dlt:TabularClassification , dlt:TimeSeriesForecasting ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Tabular"@en .

dlt:CV
      a       skos:Collection ;
      skos:member dlt:ImageToImage , dlt:ObjectDetection , dlt:ZeroShotImageClassification , dlt:ImageFeatureExtraction , dlt:ImageSegmentation , dlt:TextTo3D , dlt:UnconditionalImageGeneration , dlt:ImageToText , dlt:KeypointDetection , dlt:ImageTo3D , dlt:TextToVideo , dlt:ZeroShotObjectDetection , dlt:ImageClassification , dlt:MaskGeneration , dlt:DepthEstimation , dlt:TextToImage , dlt:VideoToVideo , dlt:ImageToVideo , dlt:VideoClassification ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Computer Vision"@en .

dlt:Multimodal
      a       skos:Collection ;
      skos:member dlt:VisualQuestionAnswering , dlt:VisualDocumentRetrieval , dlt:DocumentQuestionAnswering , dlt:AudioTextToText , dlt:ImageTextToImage , dlt:AnyToAny , dlt:VideoTextToText , dlt:ImageTextToVideo , dlt:ImageTextToText ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Multimodal"@en .

dlt:Audio
      a       skos:Collection ;
      skos:member dlt:AutomaticSpeechRecognition , dlt:AudioClassification , dlt:TextToAudio , dlt:TextToSpeech , dlt:AudioToAudio , dlt:VoiceActivityDetection ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Audio"@en .

# ----------------------------------- Task Categories

dlt:DocumentQuestionAnswering
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Document Question Answering (also known as Document Visual Question Answering) is the task of answering questions on document images. Document question answering models take a (document, question) pair as input and return an answer in natural language. Models usually rely on multi-modal features, combining text, position of words (bounding-boxes) and image."@en ;
      skos:example "Dataset example: Largest document understanding dataset."@en , "Library example: transformers."@en , "Model example: A robust document question answering model."@en , "Demo example: A robust document question answering application."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Document Question Answering"@en .

dlt:AudioClassification
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Audio classification is the task of assigning a label or class to a given audio. It can be used for recognizing which command a user is giving or the emotion of a statement, as well as identifying a speaker."@en ;
      skos:example "Library example: speechbrain."@en , "Demo example: An application that can classify music into different genre."@en , "Dataset example: A benchmark of 10 different audio tasks."@en , "Model example: An easy-to-use model for command recognition."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Audio Classification"@en .

dlt:ImageToImage
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-to-image is the task of transforming an input image through a variety of possible manipulations and enhancements, such as super-resolution, image inpainting, colorization, and more."@en ;
      skos:example "Library example: diffusers."@en , "Dataset example: Synthetic dataset, for image relighting"@en , "Demo example: Image editing application."@en , "Model example: An image-to-image model to improve image resolution."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Image-to-Image"@en .

dlt:TabularRegression
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Tabular regression is the task of predicting a numerical value given a set of attributes."@en ;
      skos:example "Model example: Fish weight prediction based on length measurements and species."@en , "Dataset example: A comprehensive curation of datasets covering all benchmarks."@en , "Demo example: An application that can predict weight of a fish based on set of attributes."@en , "Library example: sklearn."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Tabular Regression"@en .

dlt:ImageSegmentation
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image Segmentation divides an image into segments where each pixel in the image is mapped to an object. This task has multiple variants such as instance segmentation, panoptic segmentation and semantic segmentation."@en ;
      skos:example "Dataset example: Scene segmentation dataset."@en , "Demo example: A semantic segmentation application that can predict unseen instances out of the box."@en , "Model example: Solid panoptic segmentation model trained on COCO."@en , "Library example: transformers."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Image Segmentation"@en .

dlt:UnconditionalImageGeneration
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Unconditional image generation is the task of generating images with no condition in any context (like a prompt text or another image). Once trained, the model will create images that resemble its training data distribution."@en ;
      skos:example "Library example: diffusers."@en , "Demo example: An application that can generate realistic faces."@en , "Dataset example: The CIFAR-100 dataset consists of 60000 32x32 colour images in 100 classes, with 600 images per class."@en , "Model example: High-quality image generation model trained on the CIFAR-10 dataset. It synthesizes images of the ten classes presented in the dataset using diffusion probabilistic models, a class of latent variable models inspired by considerations from nonequilibrium thermodynamics."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Unconditional Image Generation"@en .

dlt:ImageToText
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image to text models output a text from a given image. Image captioning or optical character recognition can be considered as the most common applications of image to text."@en ;
      skos:example "Library example: transformers."@en , "Model example: Strong OCR model."@en , "Dataset example: Dataset from 12M image-text of Reddit"@en , "Demo example: SVG generator app from images."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Image-to-Text"@en .

dlt:AnyToAny
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Any-to-any models can understand two or more modalities and output two or more modalities."@en ;
      skos:example "Demo example: An application to chat with an any-to-any (image & text) model."@en , "Dataset example: A dataset with multiple modality input and output pairs."@en , "Model example: Strong model that can take in video, audio, image, text and output text and natural speech."@en , "Library example: transformers."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Any-to-Any"@en .

dlt:ZeroShotClassification
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Zero-shot text classification is a task in natural language processing where a model is trained on a set of labeled records but is then able to classify new records from previously unseen classes."@en ;
      skos:example "Dataset example: A widely used dataset used to benchmark multiple variants of text classification."@en , "Model example: Powerful zero-shot text classification model."@en , "Library example: transformers."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Zero Shot classification"@en .

dlt:TimeSeriesForecasting
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/models-tags-by-type?type=pipeline_tag> ;
      owl:seeAlso <https://en.wikipedia.org/wiki/Time_series> ;
      skos:definition "Time series forecasting is the task of predicting future values based on previously observed values."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Time Series Forecasting"@en .

dlt:ZeroShotObjectDetection
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Zero-shot object detection is a computer vision task to detect objects and their classes in images, without any prior training or knowledge of the classes. Zero-shot object detection models receive an image as input, as well as a list of candidate classes, and output the bounding boxes and labels where the objects have been detected."@en ;
      skos:example "Model example: Solid zero-shot object detection model."@en , "Demo example: A demo to compare different zero-shot object detection models per output and latency."@en , "Library example: transformers."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Zero Shot object detection"@en .

dlt:Robotics
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/models-tags-by-type?type=pipeline_tag> ;
      owl:seeAlso <https://www.wikidata.org/wiki/Q170978> ;
      skos:definition "Robotics is the task of improving the perception, decision-making, and interaction capabilities of robots."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Robotics"@en .

dlt:ReinforcementLearning
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Reinforcement learning is the computational approach of learning from action by interacting with an environment through trial and error and receiving rewards (negative or positive) as feedback"@en ;
      skos:example "Dataset example: A curation of widely used datasets for Data Driven Deep Reinforcement Learning (D4RL)"@en , "Demo example: An application for a cute puppy agent learning to catch a stick."@en , "Model example: A Reinforcement Learning model trained on expert data from the Gym Hopper environment"@en , "Library example: transformers."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Reinforcement Learning"@en .

dlt:MaskGeneration
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Mask generation is the task of generating masks that identify a specific object or region of interest in a given image. Masks are often used in segmentation tasks, where they provide a precise way to isolate the object of interest for further processing or analysis."@en ;
      skos:example "Model example: Small yet powerful mask generation model."@en , "Demo example: An application that combines a mask generation model with a zero-shot object detection model for text-guided image segmentation."@en , "Dataset example: Widely used benchmark dataset for multiple Vision tasks."@en , "Library example: transformers."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Mask Generation"@en .

dlt:FeatureExtraction
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Feature extraction is the task of extracting features learnt in a model."@en ;
      skos:example "Demo example: A leaderboard to rank text feature extraction models based on a benchmark."@en , "Model example: A powerful feature extraction model for natural language processing tasks."@en , "Dataset example: Wikipedia dataset containing cleaned articles of all languages. Can be used to train `feature-extraction` models."@en , "Library example: sentence-transformers."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Feature Extraction"@en .

dlt:TextToAudio
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/models-tags-by-type?type=pipeline_tag> ;
      owl:seeAlso <https://huggingface.co/tasks/text-to-speech> ;
      skos:definition "Text-to-audio, also known as text-to-speech (TTS), is the task of generating natural sounding speech given text input."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Text-to-Audio"@en .

dlt:AudioToAudio
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Audio-to-Audio is a family of tasks in which the input is an audio and the output is one or multiple generated audios. Some example tasks are speech enhancement and source separation."@en ;
      skos:example "Demo example: An application for speech separation."@en , "Library example: asteroid."@en , "Model example: A speech enhancement model."@en , "Dataset example: 512-element X-vector embeddings of speakers from CMU ARCTIC dataset."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Audio-to-Audio"@en .

dlt:ImageToVideo
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-to-video models take a still image as input and generate a video. These models can be guided by text prompts to influence the content and style of the output video."@en ;
      skos:example "Library example: diffusers."@en , "Dataset example: A benchmark dataset for reference image controlled video generation."@en , "Demo example: An application to generate videos fast."@en , "Model example: LTX-Video, a 13B parameter model for high quality video generation"@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Image-to-Video"@en .

dlt:VideoClassification
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Video classification is the task of assigning a label or class to an entire video. Videos are expected to have only one class for each video. Video classification models take a video as input and return a prediction about which class the video belongs to."@en ;
      skos:example "Demo example: An application that classifies video at different timestamps."@en , "Dataset example: Benchmark dataset used for video classification with videos that belong to 400 classes."@en , "Library example: transformers."@en , "Model example: Strong Video Classification model trained on the Kinetics 400 dataset."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Video Classification"@en .

dlt:TabularToText
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_categories> ;
      skos:definition "Tabular-to-text is the task of converting structured tabular data into fluent and coherent natural language text."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Tabular-to-Text"@en .

dlt:FillMask
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Masked language modeling is the task of masking some of the words in a sentence and predicting which words should replace those masks. These models are useful when we want to get a statistical understanding of the language in which the model is trained in."@en ;
      skos:example "Dataset example: A common dataset that is used to train models for many languages."@en , "Model example: State-of-the-art masked language model."@en , "Library example: transformers."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Fill Mask"@en .

dlt:ObjectDetection
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Object Detection models allow users to identify objects of certain defined classes. Object detection models receive an image as input and output the images with bounding boxes and labels on detected objects."@en ;
      skos:example "Dataset example: Widely used benchmark dataset for multiple vision tasks."@en , "Model example: Solid object detection model pre-trained on the COCO 2017 dataset."@en , "Demo example: Real-time object detection demo."@en , "Library example: transformers."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Object Detection"@en .

dlt:ZeroShotImageClassification
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Zero-shot image classification is the task of classifying previously unseen classes during training of a model."@en ;
      skos:example "Model example: Multilingual image classification model for 80 languages."@en , "Library example: transformers."@en , "Demo example: An application that leverages zero-shot image classification to find best captions to generate an image."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Zero Shot image classification"@en .

dlt:TokenClassification
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Token classification is a natural language understanding task in which a label is assigned to some tokens in a text. Some popular token classification subtasks are Named Entity Recognition (NER) and Part-of-Speech (PoS) tagging. NER models could be trained to identify specific entities in a text, such as dates, individuals and places; and PoS tagging would identify, for example, which words in a text are verbs, nouns, and punctuation marks."@en ;
      skos:example "Dataset example: A widely used dataset useful to benchmark named entity recognition models."@en , "Demo example: An application that can recognizes entities, extracts noun chunks and recognizes various linguistic features of each token."@en , "Library example: adapter-transformers."@en , "Model example: A robust performance model to identify people, locations, organizations and names of miscellaneous entities."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Token Classification"@en .

dlt:ImageFeatureExtraction
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image feature extraction is the task of extracting features learnt in a computer vision model."@en ;
      skos:example "Model example: A powerful image feature extraction model."@en , "Dataset example: ImageNet-1K is a image classification dataset in which images are used to train image-feature-extraction models."@en , "Library example: timm."@en , "Demo example: A leaderboard to evaluate different image-feature-extraction models on classification performances"@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Image Feature Extraction"@en .

dlt:TextToVideo
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text-to-video models can be used in any application that requires generating consistent sequence of images from text."@en ;
      skos:example "Library example: diffusers."@en , "Demo example: An application that generates video from text."@en , "Dataset example: Microsoft Research Video to Text is a large-scale dataset for open domain video captioning"@en , "Model example: A strong model for consistent video generation."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Text-to-Video"@en .

dlt:ImageClassification
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image classification is the task of assigning a label or class to an entire image. Images are expected to have only one class for each image. Image classification models take an image as input and return a prediction about which class the image belongs to."@en ;
      skos:example "Demo example: A leaderboard to evaluate different image classification models."@en , "Model example: A strong image classification model."@en , "Library example: keras."@en , "Dataset example: Benchmark dataset used for image classification with images that belong to 100 classes."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Image Classification"@en .

dlt:TextGeneration
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Generating text is the task of generating new text given another text. These models can, for example, fill in incomplete text or paraphrase."@en ;
      skos:example "Model example: A text-generation model trained to follow instructions."@en , "Demo example: An application that writes and executes code from text instructions and supports many models."@en , "Dataset example: Multilingual dataset used to evaluate text generation models."@en , "Library example: transformers."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Text Generation"@en .

dlt:TabularClassification
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Tabular classification is the task of classifying a target category (a group) based on set of attributes."@en ;
      skos:example "Demo example: An application that can predict defective products on a production line."@en , "Dataset example: A comprehensive curation of datasets covering all benchmarks."@en , "Model example: Breast cancer prediction model based on decision trees."@en , "Library example: sklearn."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Tabular Classification"@en .

dlt:MultipleChoice
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_categories> ;
      owl:seeAlso <https://www.wikidata.org/wiki/Q28060611> , <https://www.wikidata.org/wiki/Q867668> , <https://huggingface.co/docs/transformers/tasks/multiple_choice> ;
      skos:definition "A multiple choice task is similar to question answering, except several candidate answers are provided along with a context and the model is trained to select the correct answer."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Multiple Choice"@en .

dlt:ImageTextToText
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-text-to-text models take in an image and text prompt and output text. These models are also called vision-language models, or VLMs. The difference from image-to-text models is that these models take an additional text input, not restricting the model to certain use cases like image captioning, and may also be trained to accept a conversation as input."@en ;
      skos:example "Model example: Small and efficient yet powerful vision language model."@en , "Demo example: Leaderboard to evaluate vision language models."@en , "Library example: transformers."@en , "Dataset example: Instructions composed of image and text."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Image Text-to-Text"@en .

dlt:VisualQuestionAnswering
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Visual Question Answering is the task of answering open-ended questions based on an image. They output natural language responses to natural language questions."@en ;
      skos:example "Model example: A visual question answering model trained to convert charts and plots to text."@en , "Library example: transformers."@en , "Demo example: An application that compares visual question answering models across different tasks."@en , "Dataset example: A widely used dataset containing questions (with answers) about images."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Visual Question Answering"@en .

dlt:Summarization
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Summarization is the task of producing a shorter version of a document while preserving its important information. Some models can extract text from the original input, while other models can generate entirely new text."@en ;
      skos:example "Model example: A strong summarization model trained on English news articles. Excels at generating factual summaries."@en , "Dataset example: News articles in five different languages along with their summaries. Widely used for benchmarking multilingual summarization models."@en , "Demo example: An application that can summarize long paragraphs."@en , "Library example: transformers."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Summarization"@en .

dlt:ImageTextToImage
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-text-to-image models take an image and a text prompt as input and generate a new image based on the reference image and text instructions. These models are useful for image editing, style transfer, image variations, and guided image generation tasks."@en ;
      skos:example "Demo example: An application for image-text-to-image generation."@en , "Library example: diffusers."@en , "Model example: A powerful model for image-text-to-image generation."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Image Text-to-Image"@en .

dlt:SentenceSimilarity
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Sentence Similarity is the task of determining how similar two texts are. Sentence similarity models convert input texts into vectors (embeddings) that capture semantic information and calculate how close (similar) they are between them. This task is particularly useful for information retrieval and clustering/grouping."@en ;
      skos:example "Model example: This model works well for sentences and paragraphs and can be used for clustering/grouping and semantic searches."@en , "Dataset example: Bing queries with relevant passages from various web sources."@en , "Demo example: An application that leverages sentence similarity to answer questions from YouTube videos."@en , "Library example: sentence-transformers."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Sentence Similarity"@en .

dlt:TextTo3D
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text-to-3D models take in text input and produce 3D output."@en ;
      skos:example "Library example: diffusers."@en , "Demo example: Text-to-3D demo with mesh outputs."@en , "Model example: Text-to-3D mesh model by OpenAI"@en , "Dataset example: A large dataset of over 10 million 3D objects."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Text-to-3D"@en .

dlt:VideoTextToText
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Video-text-to-text models take in a video and a text prompt and output text. These models are also called video-language models."@en ;
      skos:example "Demo example: An application to chat with a video-text-to-text model."@en , "Model example: A robust video-text-to-text model."@en , "Library example: transformers."@en , "Dataset example: Multiple-choice questions and answers about videos."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Video Text-to-Text"@en .

dlt:ImageTo3D
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-to-3D models take in image input and produce 3D output."@en ;
      skos:example "Model example: Fast image-to-3D mesh model by Tencent."@en , "Library example: diffusers."@en , "Demo example: Leaderboard to evaluate image-to-3D models."@en , "Dataset example: A large dataset of over 10 million 3D objects."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Image-to-3D"@en .

dlt:VisualDocumentRetrieval
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Visual document retrieval is the task of searching for relevant image-based documents, such as PDFs. These models take a text query and multiple documents as input and return the top-most relevant documents and relevancy scores as output."@en ;
      skos:example "Model example: Very accurate visual document retrieval model for multilingual queries and documents."@en , "Dataset example: A large dataset used to train visual document retrieval models."@en , "Library example: transformers."@en , "Demo example: A leaderboard of visual document retrieval models."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Visual Document Retrieval"@en .

dlt:AutomaticSpeechRecognition
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Automatic Speech Recognition (ASR), also known as Speech to Text (STT), is the task of transcribing a given audio to text. It has many applications, such as voice user interfaces."@en ;
      skos:example "Demo example: A powerful general-purpose speech recognition application."@en , "Model example: A powerful ASR model by OpenAI."@en , "Dataset example: 31,175 hours of multilingual audio-text dataset in 108 languages."@en , "Library example: espnet."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Automatic Speech Recognition"@en .

dlt:AudioTextToText
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Audio-text-to-text models take both an audio clip and a text prompt as input, and generate natural language text as output. These models can answer questions about spoken content, summarize meetings, analyze music, or interpret speech beyond simple transcription. They are useful for applications that combine speech understanding with reasoning or conversation."@en ;
      skos:example "Dataset example: A dataset containing audio conversations with question–answer pairs."@en , "Library example: transformers."@en , "Demo example: A space that takes input as both audio and text and generates answers."@en , "Model example: A lightweight model that has capabilities of taking both audio and text as inputs and generating responses."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Audio Text-to-Text"@en .

dlt:TextRetrieval
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_categories> ;
      owl:seeAlso <https://www.wikidata.org/wiki/Q816826> ;
      skos:definition "Text retrieval is the task of obtaining information resources relevant to an information need from text."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Text Retrieval"@en .

dlt:DepthEstimation
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Depth estimation is the task of predicting depth of the objects present in an image."@en ;
      skos:example "Model example: Cutting-edge depth estimation model."@en , "Dataset example: NYU Depth V2 Dataset: Video dataset containing both RGB and depth sensor data."@en , "Library example: transformers."@en , "Demo example: An application that predicts the depth of an image and then reconstruct the 3D model as voxels."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Depth Estimation"@en .

dlt:TableToText
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_categories> ;
      skos:definition "Table-to-text is the task of converting structured tabular data into fluent and coherent natural language text."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Table-to-Text"@en .

dlt:ImageTextToVideo
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-text-to-video models take an reference image and a text instructions as and generate a video based on them. These models are useful for animating still images, creating dynamic content from static references, and generating videos with specific motion or transformation guidance."@en ;
      skos:example "Library example: diffusers."@en , "Model example: A powerful model for image-text-to-video generation."@en , "Demo example: An application for image-text-to-video generation."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Image Text-to-Video"@en .

dlt:TableQuestionAnswering
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Table Question Answering (Table QA) is the answering a question about an information on a given table."@en ;
      skos:example "Demo example: An application that answers questions based on table CSV files."@en , "Dataset example: The WikiTableQuestions dataset is a large-scale dataset for the task of question answering on semi-structured tables."@en , "Library example: transformers."@en , "Model example: A table question answering model that is capable of neural SQL execution, i.e., employ TAPEX to execute a SQL query on a given table."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Table Question Answering"@en .

dlt:QuestionAnswering
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Question Answering models can retrieve the answer to a question from a given text, which is useful for searching for an answer in a document. Some question answering models can generate answers without context!"@en ;
      skos:example "Library example: adapter-transformers."@en , "Demo example: An application that can answer a long question from Wikipedia."@en , "Dataset example: A famous question answering dataset based on English articles from Wikipedia."@en , "Model example: A robust baseline model for most question answering domains."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Question Answering"@en .

dlt:GraphML
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/models-tags-by-type?type=pipeline_tag> ;
      owl:seeAlso <https://www.wikidata.org/wiki/Q120799625> ;
      skos:definition "Graph machine learning is a machine learning approach for graph data."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Graph Machine Learning"@en .

dlt:Translation
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Translation is the task of converting text from one language to another."@en ;
      skos:example "Model example: Very powerful model that can translate many languages between each other, especially low-resource languages."@en , "Library example: transformers."@en , "Dataset example: A dataset of copyright-free books translated into 16 different languages."@en , "Demo example: An application that can translate between 100 languages."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Translation"@en .

dlt:KeypointDetection
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Keypoint detection is the task of identifying meaningful distinctive points or features in an image."@en ;
      skos:example "Dataset example: A dataset of hand keypoints of over 500k records."@en , "Model example: A robust keypoint detection model."@en , "Library example: transformers."@en , "Demo example: An application that detects hand keypoints in real-time."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Keypoint Detection"@en .

dlt:VoiceActivityDetection
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/models-tags-by-type?type=pipeline_tag> ;
      owl:seeAlso <https://www.wikidata.org/wiki/Q1332614> ;
      skos:definition "Voice activity detection is the task of detecting the presence or absence of human speech."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Voice Activity Detection"@en .

dlt:TextClassification
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text Classification is the task of assigning a label or class to a given text. Some use cases are sentiment analysis, natural language inference, and assessing grammatical correctness."@en ;
      skos:example "Model example: A robust model trained for sentiment analysis."@en , "Dataset example: A widely used dataset used to benchmark multiple variants of text classification."@en , "Library example: adapter-transformers."@en , "Demo example: An application that can classify financial sentiment."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Text Classification"@en .

dlt:TextToSpeech
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text-to-Speech (TTS) is the task of generating natural sounding speech given text input. TTS models can be extended to have a single model that generates speech for multiple speakers and multiple languages."@en ;
      skos:example "Model example: Small yet powerful TTS model."@en , "Dataset example: 10K hours of multi-speaker English dataset."@en , "Demo example: An application for generate high quality speech in different languages."@en , "Library example: espnet."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Text-to-Speech"@en .

dlt:TextToImage
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text-to-image is the task of generating images from input text. These pipelines can also be used to modify and edit images based on text prompts."@en ;
      skos:example "Library example: diffusers."@en , "Dataset example: RedCaps is a large-scale dataset of 12M image-text pairs collected from Reddit."@en , "Model example: One of the most powerful image generation models that can generate realistic outputs."@en , "Demo example: A powerful text-to-image application."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Text-to-Image"@en .

dlt:VideoToVideo
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Video-to-video models take one or more videos as input and generate new videos as output. They can enhance quality, interpolate frames, modify styles, or create new motion dynamics, enabling creative applications, video production, and research."@en ;
      skos:example "Dataset example: Dataset with detailed annotations for training and benchmarking video instance editing."@en , "Library example: diffusers."@en , "Model example: Model for editing outfits, character, and scenery in videos."@en , "Demo example: Interactive demo space for Lucy-Edit-Dev video editing."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Video-to-Video"@en .

dlt:TextRanking
      a       dlo:Task , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text Ranking is the task of ranking a set of texts based on their relevance to a query. Text ranking models are trained on large datasets of queries and relevant documents to learn how to rank documents based on their relevance to the query. This task is particularly useful for search engines and information retrieval systems."@en ;
      skos:example "Model example: An extremely efficient text ranking model trained on a web search dataset."@en , "Dataset example: Bing queries with relevant passages from various web sources."@en , "Library example: sentence-transformers."@en ;
      skos:inScheme dlt:TaskScheme ;
      skos:prefLabel "Text Ranking"@en .

