<#DatasetPapersWithCodeArticleLink>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, paperswithcode_id:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#dataset/sha1({$.id})";
        rr:termType rr:IRI;
    ];
    rr:predicateObjectMap [
        rr:predicate mluo:hasAcademicArticle;
        rr:objectMap [ rr:template "http://example.org/mluo/data#article/sha1(pwc_{$.paperswithcode_id})"; rr:termType rr:IRI ];
    ];
    .


<#AcademicArticlePapersWithCode>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({paperswithcode_id:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#article/sha1(pwc_{$.paperswithcode_id})";
        rr:termType rr:IRI;
        rr:class mluo:AcademicArticle;
    ];
    rr:predicateObjectMap [
        rr:predicate mluo:paperswithcode_id;
        rr:objectMap [ xrr:reference "$.paperswithcode_id" ];
    ];
    .


<#Distribution>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#distribution/sha1({$.id})";
        rr:termType rr:IRI;
        rr:class dcat:Distribution;
    ];
    rr:predicateObjectMap [
        rr:predicate dcat:accessURL;
        rr:objectMap [ rr:template "https://huggingface.co/datasets/{$.id}"; rr:termType rr:IRI ];
    ];
    .


<#Creator>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, author:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#creator/{$.author}";
        rr:termType rr:IRI;
        rr:class foaf:Agent;
    ];
    rr:predicateObjectMap [
        rr:predicate foaf:name;
        rr:objectMap [ xrr:reference "$.author" ];
    ];
    .


<#Publisher>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.findOne({id:{$exists:true}})";
    ];
    rr:subjectMap [
        rr:constant "http://example.org/mluo/data#publisher/HuggingFace";
        rr:termType rr:IRI;
        rr:class foaf:Organization;
    ];
    rr:predicateObjectMap [
        rr:predicate foaf:name;
        rr:objectMap [ rr:constant "HuggingFace" ];
    ];
    .

