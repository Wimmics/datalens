      skos:broader mluo_th:text-generation ;
      skos:prefLabel "Language Modeling"@en .

mluo_th:feature-extraction
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Feature extraction is the task of extracting features learnt in a model."@en ;
