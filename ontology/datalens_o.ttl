@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix oa: <http://www.w3.org/ns/oa#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix prov: <http://www.w3.org/ns/prov#> .


@prefix dlo: <http://ns.inria.fr/datalens/ontology/> .

# Name idea : dlo : Datalens Ontology

dlo: a owl:Ontology ;
    dcterms:title "Datalens Ontology"@en ;
    dcterms:creator "Aline MENIN", "Zachari ARNAUD" ;
    dcterms:modified "2026-05-6" ;
    dcterms:description "The Datalens Ontology defines concepts and relationships for datasets and machine learning models."@en ;
    owl:versionInfo "1.0" ;
    dcat:landingPage <https://github.com/amenin/datalens> ;
    dcterms:license  <https://www.apache.org/licenses/LICENSE-2.0> ;
    dcterms:created "2026"^^xsd:gYear ;
    dcterms:publisher "Inria", "University Côte d'Azur", "CNRS" .

## Concepts related to both datasets and models
dlo:SubTask a owl:Class ;
    rdfs:label "Machine Learning Sub-task"@en ;
    rdfs:comment "A specific sub-task or problem that a machine learning model is designed to solve."@en .

dlo:Task a owl:Class ;
    rdfs:label "Task"@en ;
    rdfs:comment "A machine learning task, such as text classification, linear regression, etc."@en . 

dlo:Modality a owl:Class ;
    rdfs:label "Modality"@en ;
    rdfs:comment "A type of data modality used in the context of machine learning."@en .

dlo:Library a owl:Class ;
    rdfs:label "Library"@en ;
    rdfs:comment "A machine learning library."@en .

   
## Concepts related to datasets
dlo:SizeCategory a owl:Class ;
    rdfs:label "Size Category"@en ;
    rdfs:comment "Categories for the size of a dataset, according to HuggingFace definition."@en .

dlo:Annotation a owl:Class ;
    rdfs:subClassOf oa:Annotation ;
    rdfs:label "Annotation"@en ;
    rdfs:comment "A comment or note related to a dataset or a machine learning model."@en .

dlo:annotationMethod a owl:DatatypeProperty ;
    rdfs:label "annotation method"@en ;
    rdfs:comment "The method or technique used to create an annotation for a dataset or a machine learning model."@en ;
    rdfs:domain dlo:Annotation ;
    rdfs:range rdfs:Literal .

dlo:linguisticMethod a owl:DatatypeProperty ;
    rdfs:label "linguistic method"@en ;
    rdfs:comment "The linguistic creation method or approach used in the context of a dataset or a machine learning model."@en ;
    rdfs:domain dlo:Annotation ;
    rdfs:range rdfs:Literal .

## Properties for both datasets and models
# dlo:isAvailable a owl:DatatypeProperty ;
#     rdfs:label "availability status"@en ;
#     rdfs:comment "The availability status of a dataset or model, indicating whether it is enabled or disabled."@en ;
#     rdfs:domain  [ 
#         a owl:Class ;
#         owl:unionOf (dcat:Dataset dlo:Model) 
#     ] ;
#     rdfs:range  xsd:boolean .

dlo:downloadCount a owl:DatatypeProperty ;
    rdfs:label "download count"@en ;
    rdfs:comment "The number of times a dataset or model has been downloaded."@en ;
    rdfs:domain  [ 
        a owl:Class ;
        owl:unionOf (dcat:Dataset dlo:Model) 
    ] ;
    rdfs:range xsd:integer .

dlo:likesCount a owl:DatatypeProperty ;
    rdfs:label "likes count"@en ;
    rdfs:comment "The number of likes or positive feedback a dataset or model has received."@en ;
    rdfs:domain  [ 
        a owl:Class ;
        owl:unionOf (dcat:Dataset dlo:Model) 
    ] ;    rdfs:range xsd:integer .

dlo:hasModality a owl:DatatypeProperty ;
    rdfs:label "has modality"@en ;
    rdfs:comment "Relates a dataset to a specific modality or type of data used in the context of machine learning."@en ;
    rdfs:domain  [ 
        a owl:Class ;
        owl:unionOf (dcat:Dataset dlo:Model) 
    ] ;
    rdfs:range dlo:Modality .

dlo:hasSubTask a owl:ObjectProperty ;
    rdfs:label "has ML sub-task"@en ;
    rdfs:comment "Relates a dataset or model to a specific sub-task."@en ;
    rdfs:domain  [ 
        a owl:Class ;
        owl:unionOf (dcat:Dataset dlo:Model) 
    ] ;
    rdfs:range dlo:SubTask .

dlo:hasTask a owl:ObjectProperty ;
    rdfs:label "has ML task"@en ;
    rdfs:comment "Relates a dataset or model to a machine learning task."@en ;
    rdfs:domain  [ 
        a owl:Class ;
        owl:unionOf (dcat:Dataset dlo:Model) 
    ] ;
    rdfs:range dlo:Task .

dlo:hasLibrary a owl:ObjectProperty ;
    rdfs:label "has library"@en ;
    rdfs:comment "Relates a dataset or model to a machine learning library."@en ;
    rdfs:domain  [ 
        a owl:Class ;
        owl:unionOf (dcat:Dataset dlo:Model) 
    ] ;
    rdfs:range dlo:Library .

dlo:hasAcademicArticle a owl:ObjectProperty ;
    rdfs:label "has scientific article"@en ;
    rdfs:comment "Relates a dataset or model to a scholarly article or paper that describes it."@en ;
    rdfs:domain  [ 
        a owl:Class ;
        owl:unionOf (dcat:Dataset dlo:Model) 
    ] ;    rdfs:range bibo:AcademicArticle .

## Properties specific to datasets
dlo:hasAnnotation a owl:ObjectProperty ;
    rdfs:label "has annotation"@en ;
    rdfs:comment "Relates a dataset to its annotations, which provide additional information or context."@en ;
    rdfs:domain dcat:Dataset ;
    rdfs:range dlo:Annotation .

dlo:hasSize a owl:DatatypeProperty ;
    rdfs:label "has size"@en ;
    rdfs:comment "Relates a dataset to a size category"@en ;
    rdfs:domain dcat:Dataset ;
    rdfs:range dlo:SizeCategory .



## Machine Learning models

@prefix mls: <http://www.w3.org/ns/mls#> .

# La class Model peut provenir de mls ou de dlo

dlo:Model a owl:Class ;
    rdfs:label "Machine Learning Model"@en ;
    rdfs:comment "A machine learning model published on a platform such as Hugging Face."@en ;
    rdfs:subClassOf schema:SoftwareSourceCode .

dlo:hasModelArchitecture a owl:DatatypeProperty ;
    rdfs:label "model architecture"@en ;
    rdfs:comment "The architecture declared by the model configuration."@en ;
    rdfs:domain dlo:Model ;
    rdfs:range dlo:ModelArchitecture .

dlo:ModelArchitecture a owl:Class ;
    rdfs:label "Model Architecture"@en ;
    rdfs:comment "The architecture of a machine learning model, such as transformer, convolutional neural network, etc."@en .

dlo:wasTrainedOn a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:wasInfluencedBy ;
    rdfs:label "was trained on"@en ;
    rdfs:comment "Relates a machine learning model to a dataset used for training or pretraining."@en ;
    rdfs:domain dlo:Model ;
    rdfs:range dcat:Dataset .

dlo:Transformation a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Model Transformation"@en ;
    rdfs:comment "A transformation or modification applied to a machine learning model."@en .