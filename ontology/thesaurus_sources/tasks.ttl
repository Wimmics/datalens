@prefix schema:  <https://schema.org/> .
@prefix rr:      <http://www.w3.org/ns/r2rml#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix mluo:    <http://example.org/mluo/ontology#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix mluo_th:  <http://example.org/mluo/thesaurus#> .
@prefix rml:     <http://semweb.mmlab.be/ns/rml#> .
@prefix oa:      <http://www.w3.org/ns/oa#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix xrr:     <http://i3s.unice.fr/xr2rml#> .
@prefix bibo:    <http://purl.org/ontology/bibo/> .
@prefix dcat:    <http://www.w3.org/ns/dcat#> .


mluo_th: a owl:Ontology ;
    dcterms:title "MLUO Thesaurus"@en ;
    dcterms:creator "Aline MENIN", "Zachari ARNAUD" ;
    dcterms:modified "2026-04-16" ;
    dcterms:description "The MLUO Thesaurus provides controlled vocabulary for datasets and machine learning models."@en ;
    owl:versionInfo "1.0" ;
    dcat:landingPage <https://github.com/amenin/datalens> ;
    dcterms:license  <https://www.apache.org/licenses/LICENSE-2.0> ;
    dcterms:created "2026"^^xsd:gYear ;
    dcterms:publisher "Inria", "University Côte d'Azur", "CNRS" .


## Task Scheme
mluo_th:TaskScheme
      a       skos:ConceptScheme ;
      skos:definition "A controlled vocabulary for describing machine learning tasks."@en ;
      skos:prefLabel "Machine Learning Task Scheme"@en .

# ----------------------------------- Collections

mluo_th:rl
      a       skos:Collection ;
      skos:hasTopConcept mluo_th:robotics , mluo_th:reinforcement-learning ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Reinforcement Learning"@en .

mluo_th:nlp
      a       skos:Collection ;
      skos:hasTopConcept mluo_th:fill-mask , mluo_th:summarization , mluo_th:question-answering , mluo_th:token-classification , mluo_th:sentence-similarity , mluo_th:translation , mluo_th:zero-shot-classification , mluo_th:text-classification , mluo_th:text-retrieval , mluo_th:text-generation , mluo_th:feature-extraction , mluo_th:multiple-choice , mluo_th:table-to-text , mluo_th:table-question-answering , mluo_th:text-ranking ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Natural Language Processing"@en .

mluo_th:tabular
      a       skos:Collection ;
      skos:hasTopConcept mluo_th:tabular-to-text , mluo_th:tabular-regression , mluo_th:tabular-classification , mluo_th:time-series-forecasting ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Tabular"@en .

mluo_th:other
      a       skos:Collection ;
      skos:hasTopConcept mluo_th:graph-ml ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Other"@en .

mluo_th:cv
      a       skos:Collection ;
      skos:hasTopConcept mluo_th:image-to-image , mluo_th:object-detection , mluo_th:zero-shot-image-classification , mluo_th:image-feature-extraction , mluo_th:image-segmentation , mluo_th:text-to-3d , mluo_th:unconditional-image-generation , mluo_th:image-to-text , mluo_th:keypoint-detection , mluo_th:image-to-3d , mluo_th:text-to-video , mluo_th:zero-shot-object-detection , mluo_th:image-classification , mluo_th:mask-generation , mluo_th:depth-estimation , mluo_th:text-to-image , mluo_th:video-to-video , mluo_th:image-to-video , mluo_th:video-classification ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Computer Vision"@en .

mluo_th:multimodal
      a       skos:Collection ;
      skos:hasTopConcept mluo_th:visual-question-answering , mluo_th:visual-document-retrieval , mluo_th:document-question-answering , mluo_th:audio-text-to-text , mluo_th:image-text-to-image , mluo_th:any-to-any , mluo_th:video-text-to-text , mluo_th:image-text-to-video , mluo_th:image-text-to-text ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Multimodal"@en .

mluo_th:audio
      a       skos:Collection ;
      skos:hasTopConcept mluo_th:automatic-speech-recognition , mluo_th:audio-classification , mluo_th:text-to-audio , mluo_th:text-to-speech , mluo_th:audio-to-audio , mluo_th:voice-activity-detection ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Audio"@en .

# ----------------------------------- Task Categories

mluo_th:document-question-answering
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Document Question Answering (also known as Document Visual Question Answering) is the task of answering questions on document images. Document question answering models take a (document, question) pair as input and return an answer in natural language. Models usually rely on multi-modal features, combining text, position of words (bounding-boxes) and image."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Document Question Answering"@en .

mluo_th:audio-classification
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Audio classification is the task of assigning a label or class to a given audio. It can be used for recognizing which command a user is giving or the emotion of a statement, as well as identifying a speaker."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Audio Classification"@en .

mluo_th:image-to-image
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-to-image is the task of transforming an input image through a variety of possible manipulations and enhancements, such as super-resolution, image inpainting, colorization, and more."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Image-to-Image"@en .

mluo_th:tabular-regression
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Tabular regression is the task of predicting a numerical value given a set of attributes."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Tabular Regression"@en .

mluo_th:image-segmentation
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image Segmentation divides an image into segments where each pixel in the image is mapped to an object. This task has multiple variants such as instance segmentation, panoptic segmentation and semantic segmentation."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Image Segmentation"@en .

mluo_th:unconditional-image-generation
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Unconditional image generation is the task of generating images with no condition in any context (like a prompt text or another image). Once trained, the model will create images that resemble its training data distribution."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Unconditional Image Generation"@en .

mluo_th:image-to-text
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image to text models output a text from a given image. Image captioning or optical character recognition can be considered as the most common applications of image to text."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Image-to-Text"@en .

mluo_th:any-to-any
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Any-to-any models can understand two or more modalities and output two or more modalities."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Any-to-Any"@en .

mluo_th:zero-shot-classification
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Zero-shot text classification is a task in natural language processing where a model is trained on a set of labeled examples but is then able to classify new examples from previously unseen classes."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Zero Shot classification"@en .

mluo_th:time-series-forecasting
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/models-tags-by-type?type=pipeline_tag> ;
      owl:seeAlso <https://en.wikipedia.org/wiki/Time_series> ;
      skos:definition "Time series forecasting is the task of predicting future values based on previously observed values."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Time Series Forecasting"@en .

mluo_th:zero-shot-object-detection
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Zero-shot object detection is a computer vision task to detect objects and their classes in images, without any prior training or knowledge of the classes. Zero-shot object detection models receive an image as input, as well as a list of candidate classes, and output the bounding boxes and labels where the objects have been detected."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Zero Shot object detection"@en .

mluo_th:robotics
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/models-tags-by-type?type=pipeline_tag> ;
      owl:seeAlso <https://www.wikidata.org/wiki/Q170978> ;
      skos:definition "Robotics is the task of improving the perception, decision-making, and interaction capabilities of robots."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Robotics"@en .

mluo_th:reinforcement-learning
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Reinforcement learning is the computational approach of learning from action by interacting with an environment through trial and error and receiving rewards (negative or positive) as feedback"@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Reinforcement Learning"@en .

mluo_th:mask-generation
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Mask generation is the task of generating masks that identify a specific object or region of interest in a given image. Masks are often used in segmentation tasks, where they provide a precise way to isolate the object of interest for further processing or analysis."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Mask Generation"@en .

mluo_th:feature-extraction
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Feature extraction is the task of extracting features learnt in a model."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Feature Extraction"@en .

mluo_th:text-to-audio
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/models-tags-by-type?type=pipeline_tag> ;
      owl:seeAlso <https://huggingface.co/tasks/text-to-speech> ;
      skos:definition "Text-to-audio, also known as text-to-speech (TTS), is the task of generating natural sounding speech given text input."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Text-to-Audio"@en .

mluo_th:audio-to-audio
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Audio-to-Audio is a family of tasks in which the input is an audio and the output is one or multiple generated audios. Some example tasks are speech enhancement and source separation."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Audio-to-Audio"@en .

mluo_th:image-to-video
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-to-video models take a still image as input and generate a video. These models can be guided by text prompts to influence the content and style of the output video."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Image-to-Video"@en .

mluo_th:video-classification
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Video classification is the task of assigning a label or class to an entire video. Videos are expected to have only one class for each video. Video classification models take a video as input and return a prediction about which class the video belongs to."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Video Classification"@en .

mluo_th:tabular-to-text
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_categories> ;
      skos:definition "Tabular-to-text is the task of converting structured tabular data into fluent and coherent natural language text."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Tabular-to-Text"@en .

mluo_th:fill-mask
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Masked language modeling is the task of masking some of the words in a sentence and predicting which words should replace those masks. These models are useful when we want to get a statistical understanding of the language in which the model is trained in."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Fill Mask"@en .

mluo_th:object-detection
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Object Detection models allow users to identify objects of certain defined classes. Object detection models receive an image as input and output the images with bounding boxes and labels on detected objects."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Object Detection"@en .

mluo_th:zero-shot-image-classification
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Zero-shot image classification is the task of classifying previously unseen classes during training of a model."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Zero Shot image classification"@en .

mluo_th:token-classification
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Token classification is a natural language understanding task in which a label is assigned to some tokens in a text. Some popular token classification subtasks are Named Entity Recognition (NER) and Part-of-Speech (PoS) tagging. NER models could be trained to identify specific entities in a text, such as dates, individuals and places; and PoS tagging would identify, for example, which words in a text are verbs, nouns, and punctuation marks."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Token Classification"@en .

mluo_th:image-feature-extraction
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image feature extraction is the task of extracting features learnt in a computer vision model."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Image Feature Extraction"@en .

mluo_th:text-to-video
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text-to-video models can be used in any application that requires generating consistent sequence of images from text."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Text-to-Video"@en .

mluo_th:image-classification
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image classification is the task of assigning a label or class to an entire image. Images are expected to have only one class for each image. Image classification models take an image as input and return a prediction about which class the image belongs to."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Image Classification"@en .

mluo_th:text-generation
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Generating text is the task of generating new text given another text. These models can, for example, fill in incomplete text or paraphrase."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Text Generation"@en .

mluo_th:tabular-classification
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Tabular classification is the task of classifying a target category (a group) based on set of attributes."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Tabular Classification"@en .

mluo_th:multiple-choice
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_categories> ;
      owl:seeAlso <https://www.wikidata.org/wiki/Q28060611> , <https://www.wikidata.org/wiki/Q867668> , <https://huggingface.co/docs/transformers/tasks/multiple_choice> ;
      skos:definition "A multiple choice task is similar to question answering, except several candidate answers are provided along with a context and the model is trained to select the correct answer."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Multiple Choice"@en .

mluo_th:image-text-to-text
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-text-to-text models take in an image and text prompt and output text. These models are also called vision-language models, or VLMs. The difference from image-to-text models is that these models take an additional text input, not restricting the model to certain use cases like image captioning, and may also be trained to accept a conversation as input."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Image Text-to-Text"@en .

mluo_th:visual-question-answering
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Visual Question Answering is the task of answering open-ended questions based on an image. They output natural language responses to natural language questions."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Visual Question Answering"@en .

mluo_th:summarization
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Summarization is the task of producing a shorter version of a document while preserving its important information. Some models can extract text from the original input, while other models can generate entirely new text."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Summarization"@en .

mluo_th:image-text-to-image
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-text-to-image models take an image and a text prompt as input and generate a new image based on the reference image and text instructions. These models are useful for image editing, style transfer, image variations, and guided image generation tasks."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Image Text-to-Image"@en .

mluo_th:sentence-similarity
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Sentence Similarity is the task of determining how similar two texts are. Sentence similarity models convert input texts into vectors (embeddings) that capture semantic information and calculate how close (similar) they are between them. This task is particularly useful for information retrieval and clustering/grouping."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Sentence Similarity"@en .

mluo_th:text-to-3d
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text-to-3D models take in text input and produce 3D output."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Text-to-3D"@en .

mluo_th:video-text-to-text
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Video-text-to-text models take in a video and a text prompt and output text. These models are also called video-language models."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Video Text-to-Text"@en .

mluo_th:image-to-3d
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-to-3D models take in image input and produce 3D output."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Image-to-3D"@en .

mluo_th:visual-document-retrieval
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Visual document retrieval is the task of searching for relevant image-based documents, such as PDFs. These models take a text query and multiple documents as input and return the top-most relevant documents and relevancy scores as output."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Visual Document Retrieval"@en .

mluo_th:automatic-speech-recognition
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Automatic Speech Recognition (ASR), also known as Speech to Text (STT), is the task of transcribing a given audio to text. It has many applications, such as voice user interfaces."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Automatic Speech Recognition"@en .

mluo_th:audio-text-to-text
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Audio-text-to-text models take both an audio clip and a text prompt as input, and generate natural language text as output. These models can answer questions about spoken content, summarize meetings, analyze music, or interpret speech beyond simple transcription. They are useful for applications that combine speech understanding with reasoning or conversation."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Audio Text-to-Text"@en .

mluo_th:text-retrieval
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_categories> ;
      owl:seeAlso <https://www.wikidata.org/wiki/Q816826> ;
      skos:definition "Text retrieval is the task of obtaining information resources relevant to an information need from text."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Text Retrieval"@en .

mluo_th:depth-estimation
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Depth estimation is the task of predicting depth of the objects present in an image."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Depth Estimation"@en .

mluo_th:table-to-text
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_categories> ;
      skos:definition "Table-to-text is the task of converting structured tabular data into fluent and coherent natural language text."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Table-to-Text"@en .

mluo_th:image-text-to-video
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-text-to-video models take an reference image and a text instructions as and generate a video based on them. These models are useful for animating still images, creating dynamic content from static references, and generating videos with specific motion or transformation guidance."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Image Text-to-Video"@en .

mluo_th:table-question-answering
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Table Question Answering (Table QA) is the answering a question about an information on a given table."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Table Question Answering"@en .

mluo_th:question-answering
