@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix xrr: <http://i3s.unice.fr/xr2rml#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@prefix mluo: <http://example.org/mluo/ontology#> .
@prefix mluo_th: <http://example.org/mluo/thesaurus#> .

@prefix geonames: <http://sws.geonames.org/> .
@prefix lexvo: <https://lexvo.org/id/> .
@prefix iana: <https://www.iana.org/assignments/media-types/> .
@prefix spdx: <https://spdx.org/licenses/> .
@prefix cc: <http://creativecommons.org/licenses/> .

<#Dataset>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#dataset/{$.dataset_hash16}";
        rr:termType rr:IRI;
        rr:class dcat:Dataset;
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:identifier;
        rr:objectMap [ rr:template "{$.id}"];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:description;
        rr:objectMap [ xrr:reference "$.description" ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:issued;
        rr:objectMap [ xrr:reference "$.created_at"; rr:datatype xsd:dateTime ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:modified;
        rr:objectMap [ xrr:reference "$.last_modified"; rr:datatype xsd:dateTime ];
    ];
    rr:predicateObjectMap [
        rr:predicate mluo:downloadCount;
        rr:objectMap [ xrr:reference "$.downloads"; rr:datatype xsd:integer ];
    ];
    rr:predicateObjectMap [
        rr:predicate mluo:likesCount;
        rr:objectMap [ xrr:reference "$.likes"; rr:datatype xsd:integer ];
    ];
    rr:predicateObjectMap [ 
        rr:predicate mluo:rowsSize; 
        rr:objectMap [ xrr:reference "$.size_categories[*]"; rr:termType rr:Literal ]; 
    ];
    rr:predicateObjectMap [ 
        rr:predicate dcterms:subject; 
        rr:objectMap [ xrr:reference "$.tags[*]"; rr:termType rr:Literal ]; 
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:source;
        rr:objectMap [ xrr:reference "$.source_datasets_values[*]"; rr:termType rr:Literal ];
    ];


    # A relier à un thésaurus
    rr:predicateObjectMap [
        rr:predicate dcterms:spatial;
        rr:objectMap [ xrr:reference "$.region_uris[*]"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [ 
        rr:predicate dcterms:language; 
        rr:objectMap [ xrr:reference "$.language_uris[*]"; rr:termType rr:IRI ]; 
    ];


    # Tâches et modalités
    rr:predicateObjectMap [
        rr:predicate mluo:hasTask; 
        rr:objectMap [ rr:template "http://example.org/mluo/thesaurus#{$.task_ids[*]}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate mluo:hasTaskCategory; 
        rr:objectMap [ rr:template "http://example.org/mluo/thesaurus#{$.task_categories[*]}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [ 
        rr:predicate mluo:hasModality; 
        rr:objectMap [ rr:template "http://example.org/mluo/thesaurus#{$.modalities[*]}"; rr:termType rr:IRI ]; 
    ];
    rr:predicateObjectMap [
        rr:predicate dcat:landingPage;
        rr:objectMap [ rr:template "https://huggingface.co/datasets/{$.id}"; rr:termType rr:IRI ];
    ];


    # Liens vers d'autres ressources
    rr:predicateObjectMap [
        rr:predicate dcterms:creator;
        rr:objectMap [ rr:template "http://example.org/mluo/data#creator/{$.creator_hash16}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcat:distribution;
        rr:objectMap [ rr:template "http://example.org/mluo/data#distribution/{$.distribution_hash16}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate mluo:hasAcademicArticle;
        rr:objectMap [ rr:template "http://example.org/mluo/data#article/{$.article_hash16}"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:publisher;
        rr:objectMap [ rr:constant "http://example.org/mluo/data#publisher/HuggingFace"; rr:termType rr:IRI ];
    ];
    .

<#DatasetAnnotationLink>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true,$ne:null}, annotation_hash16:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [ rr:template "http://example.org/mluo/data#dataset/{$.dataset_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [
        rr:predicate mluo:hasAnnotation;
        rr:objectMap [ rr:template "http://example.org/mluo/data#annotation/{$.annotation_hash16}"; rr:termType rr:IRI ];
    ];
    .

<#DatasetAccessPublic>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, private:false, gated:false})";
    ];
    rr:subjectMap [ rr:template "http://example.org/mluo/data#dataset/{$.dataset_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate dcterms:accessRights; rr:objectMap [ rr:constant "public"; rr:termType rr:Literal ]; ];
    .

<#DatasetAccessRestricted>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, $or:[{private:true},{gated:true}]})";
    ];
    rr:subjectMap [ rr:template "http://example.org/mluo/data#dataset/{$.dataset_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate dcterms:accessRights; rr:objectMap [ rr:constant "restricted"; rr:termType rr:Literal ]; ];
    .

<#DatasetAvailabilityTrue>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, disabled:false})";
    ];
    rr:subjectMap [ rr:template "http://example.org/mluo/data#dataset/{$.dataset_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate mluo:isAvailable; rr:objectMap [ rr:constant "true"; rr:datatype xsd:boolean ]; ];
    .

<#DatasetAvailabilityFalse>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, disabled:true})";
    ];
    rr:subjectMap [ rr:template "http://example.org/mluo/data#dataset/{$.dataset_hash16}"; rr:termType rr:IRI; ];
    rr:predicateObjectMap [ rr:predicate mluo:isAvailable; rr:objectMap [ rr:constant "false"; rr:datatype xsd:boolean ]; ];
    .

<#AcademicArticlePapersWithCode>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({paperswithcode_id:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#article/{$.article_hash16}";
        rr:termType rr:IRI;
        rr:class mluo:AcademicArticle;
    ];
    rr:predicateObjectMap [ 
        rr:predicate mluo:paperswithcode_id; 
        rr:objectMap [ xrr:reference "$.paperswithcode_id" ]; 
    ];

    # A rajouter pour les autres métadonnées de l'article (titre, auteurs, date de publication, etc.)
    .

<#Annotation>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true,$ne:null}, annotation_hash16:{$exists:true,$ne:null}, annotation:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#annotation/{$.annotation_hash16}";
        rr:termType rr:IRI;
        rr:class mluo:Annotation;
    ];
    rr:predicateObjectMap [ 
        rr:predicate mluo:hasAnnotation; 
        rr:objectMap [ xrr:reference "$.annotation" ]; 
    ];
    .

<#Distribution>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#distribution/{$.distribution_hash16}";
        rr:termType rr:IRI;
        rr:class dcat:Distribution;
    ];
    
    # A relier à un thésaurus
    rr:predicateObjectMap [
        rr:predicate dcterms:format;
        rr:objectMap [ xrr:reference "$.format_uris[*]"; rr:termType rr:IRI ];
    ];
    rr:predicateObjectMap [
        rr:predicate dcterms:license;
        rr:objectMap [ xrr:reference "$.license_uris[*]"; rr:termType rr:IRI ];
    ];
    .

<#Creator>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.find({id:{$exists:true}, author:{$exists:true,$ne:null}})";
    ];
    rr:subjectMap [
        rr:template "http://example.org/mluo/data#creator/{$.creator_hash16}";
        rr:termType rr:IRI;
        rr:class foaf:Agent;
    ];
    rr:predicateObjectMap [ rr:predicate foaf:name; rr:objectMap [ xrr:reference "$.author" ]; ];
    .

<#Publisher>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.{{collection}}.findOne({id:{$exists:true}})";
    ];
    rr:subjectMap [
        rr:constant "http://example.org/mluo/data#publisher/HuggingFace";
        rr:termType rr:IRI;
        rr:class foaf:Organization;
    ];
    rr:predicateObjectMap [ rr:predicate foaf:name; rr:objectMap [ rr:constant "HuggingFace" ]; ];
    .

