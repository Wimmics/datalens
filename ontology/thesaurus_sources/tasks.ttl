      owl:seeAlso <https://www.wikidata.org/wiki/Q120799625> ;
      skos:definition "Graph machine learning is a machine learning approach for graph data."@en ;
      skos:inScheme mluo_th:TaskScheme ;
      skos:prefLabel "Graph Machine Learning"@en .

mluo_th:translation
      a       mluo:TaskCategory , skos:Concept ;
