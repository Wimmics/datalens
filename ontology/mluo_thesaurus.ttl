mluo_th:open-domain-qa a skos:Concept, mluo:Task ;
    skos:prefLabel "Open Domain Qa"@en ;
    skos:inScheme mluo_th:TaskScheme ;
    skos:broader mluo_th:question-answering .

mluo_th:masked-language-modeling a skos:Concept, mluo:Task ;
