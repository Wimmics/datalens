      skos:broader mluo_th:text-generation ;
      skos:prefLabel "Explanation Generation"@en .

mluo_th:unconditional-image-generation
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Unconditional image generation is the task of generating images with no condition in any context (like a prompt text or another image). Once trained, the model will create images that resemble its training data distribution."@en ;
      skos:inScheme mluo_th:cv ;
      skos:prefLabel "Unconditional Image Generation"@en ;
      skos:topConceptOf mluo_th:cv .

mluo_th:image-to-text
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image to text models output a text from a given image. Image captioning or optical character recognition can be considered as the most common applications of image to text."@en ;
      skos:inScheme mluo_th:cv ;
      skos:prefLabel "Image-to-Text"@en ;
      skos:topConceptOf mluo_th:cv .

mluo_th:any-to-any
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Any-to-any models can understand two or more modalities and output two or more modalities."@en ;
      skos:inScheme mluo_th:multimodal ;
      skos:prefLabel "Any-to-Any"@en ;
      skos:topConceptOf mluo_th:multimodal .

mluo_th:zero-shot-classification
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Zero-shot text classification is a task in natural language processing where a model is trained on a set of labeled examples but is then able to classify new examples from previously unseen classes."@en ;
      skos:inScheme mluo_th:nlp ;
      skos:prefLabel "Zero Shot classification"@en ;
      skos:topConceptOf mluo_th:nlp .

mluo_th:time-series-forecasting
