## Task Scheme
datalens_th:TaskScheme
      a       skos:ConceptScheme ;
      skos:definition "A controlled vocabulary for describing machine learning tasks."@en ;
      skos:prefLabel "Machine Learning Task Scheme"@en .

# ----------------------------------- Collections

datalens_th:rl
      a       skos:Collection ;
      skos:hasTopConcept datalens_th:robotics , datalens_th:reinforcement-learning ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Reinforcement Learning"@en .

datalens_th:nlp
      a       skos:Collection ;
      skos:hasTopConcept datalens_th:fill-mask , datalens_th:summarization , datalens_th:question-answering , datalens_th:token-classification , datalens_th:sentence-similarity , datalens_th:translation , datalens_th:zero-shot-classification , datalens_th:text-classification , datalens_th:text-retrieval , datalens_th:text-generation , datalens_th:feature-extraction , datalens_th:multiple-choice , datalens_th:table-to-text , datalens_th:table-question-answering , datalens_th:text-ranking ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Natural Language Processing"@en .

datalens_th:tabular
      a       skos:Collection ;
      skos:hasTopConcept datalens_th:tabular-to-text , datalens_th:tabular-regression , datalens_th:tabular-classification , datalens_th:time-series-forecasting ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Tabular"@en .

datalens_th:other
      a       skos:Collection ;
      skos:hasTopConcept datalens_th:graph-ml ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Other"@en .

datalens_th:cv
      a       skos:Collection ;
      skos:hasTopConcept datalens_th:image-to-image , datalens_th:object-detection , datalens_th:zero-shot-image-classification , datalens_th:image-feature-extraction , datalens_th:image-segmentation , datalens_th:text-to-3d , datalens_th:unconditional-image-generation , datalens_th:image-to-text , datalens_th:keypoint-detection , datalens_th:image-to-3d , datalens_th:text-to-video , datalens_th:zero-shot-object-detection , datalens_th:image-classification , datalens_th:mask-generation , datalens_th:depth-estimation , datalens_th:text-to-image , datalens_th:video-to-video , datalens_th:image-to-video , datalens_th:video-classification ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Computer Vision"@en .

datalens_th:multimodal
      a       skos:Collection ;
      skos:hasTopConcept datalens_th:visual-question-answering , datalens_th:visual-document-retrieval , datalens_th:document-question-answering , datalens_th:audio-text-to-text , datalens_th:image-text-to-image , datalens_th:any-to-any , datalens_th:video-text-to-text , datalens_th:image-text-to-video , datalens_th:image-text-to-text ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Multimodal"@en .

datalens_th:audio
      a       skos:Collection ;
      skos:hasTopConcept datalens_th:automatic-speech-recognition , datalens_th:audio-classification , datalens_th:text-to-audio , datalens_th:text-to-speech , datalens_th:audio-to-audio , datalens_th:voice-activity-detection ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Audio"@en .

# ----------------------------------- Task Categories

datalens_th:document-question-answering
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Document Question Answering (also known as Document Visual Question Answering) is the task of answering questions on document images. Document question answering models take a (document, question) pair as input and return an answer in natural language. Models usually rely on multi-modal features, combining text, position of words (bounding-boxes) and image."@en ;
      skos:example "Dataset example: Largest document understanding dataset."@en , "Library example: transformers."@en , "Model example: A robust document question answering model."@en , "Demo example: A robust document question answering application."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Document Question Answering"@en .

datalens_th:audio-classification
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Audio classification is the task of assigning a label or class to a given audio. It can be used for recognizing which command a user is giving or the emotion of a statement, as well as identifying a speaker."@en ;
      skos:example "Library example: speechbrain."@en , "Demo example: An application that can classify music into different genre."@en , "Dataset example: A benchmark of 10 different audio tasks."@en , "Model example: An easy-to-use model for command recognition."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Audio Classification"@en .

datalens_th:image-to-image
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-to-image is the task of transforming an input image through a variety of possible manipulations and enhancements, such as super-resolution, image inpainting, colorization, and more."@en ;
      skos:example "Library example: diffusers."@en , "Dataset example: Synthetic dataset, for image relighting"@en , "Demo example: Image editing application."@en , "Model example: An image-to-image model to improve image resolution."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Image-to-Image"@en .

datalens_th:tabular-regression
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Tabular regression is the task of predicting a numerical value given a set of attributes."@en ;
      skos:example "Model example: Fish weight prediction based on length measurements and species."@en , "Dataset example: A comprehensive curation of datasets covering all benchmarks."@en , "Demo example: An application that can predict weight of a fish based on set of attributes."@en , "Library example: sklearn."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Tabular Regression"@en .

datalens_th:image-segmentation
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image Segmentation divides an image into segments where each pixel in the image is mapped to an object. This task has multiple variants such as instance segmentation, panoptic segmentation and semantic segmentation."@en ;
      skos:example "Dataset example: Scene segmentation dataset."@en , "Demo example: A semantic segmentation application that can predict unseen instances out of the box."@en , "Model example: Solid panoptic segmentation model trained on COCO."@en , "Library example: transformers."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Image Segmentation"@en .

datalens_th:unconditional-image-generation
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Unconditional image generation is the task of generating images with no condition in any context (like a prompt text or another image). Once trained, the model will create images that resemble its training data distribution."@en ;
      skos:example "Library example: diffusers."@en , "Demo example: An application that can generate realistic faces."@en , "Dataset example: The CIFAR-100 dataset consists of 60000 32x32 colour images in 100 classes, with 600 images per class."@en , "Model example: High-quality image generation model trained on the CIFAR-10 dataset. It synthesizes images of the ten classes presented in the dataset using diffusion probabilistic models, a class of latent variable models inspired by considerations from nonequilibrium thermodynamics."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Unconditional Image Generation"@en .

datalens_th:image-to-text
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image to text models output a text from a given image. Image captioning or optical character recognition can be considered as the most common applications of image to text."@en ;
      skos:example "Library example: transformers."@en , "Model example: Strong OCR model."@en , "Dataset example: Dataset from 12M image-text of Reddit"@en , "Demo example: SVG generator app from images."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Image-to-Text"@en .

datalens_th:any-to-any
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Any-to-any models can understand two or more modalities and output two or more modalities."@en ;
      skos:example "Demo example: An application to chat with an any-to-any (image & text) model."@en , "Dataset example: A dataset with multiple modality input and output pairs."@en , "Model example: Strong model that can take in video, audio, image, text and output text and natural speech."@en , "Library example: transformers."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Any-to-Any"@en .

datalens_th:zero-shot-classification
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Zero-shot text classification is a task in natural language processing where a model is trained on a set of labeled examples but is then able to classify new examples from previously unseen classes."@en ;
      skos:example "Dataset example: A widely used dataset used to benchmark multiple variants of text classification."@en , "Model example: Powerful zero-shot text classification model."@en , "Library example: transformers."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Zero Shot classification"@en .

datalens_th:time-series-forecasting
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/models-tags-by-type?type=pipeline_tag> ;
      owl:seeAlso <https://en.wikipedia.org/wiki/Time_series> ;
      skos:definition "Time series forecasting is the task of predicting future values based on previously observed values."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Time Series Forecasting"@en .

datalens_th:zero-shot-object-detection
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Zero-shot object detection is a computer vision task to detect objects and their classes in images, without any prior training or knowledge of the classes. Zero-shot object detection models receive an image as input, as well as a list of candidate classes, and output the bounding boxes and labels where the objects have been detected."@en ;
      skos:example "Model example: Solid zero-shot object detection model."@en , "Demo example: A demo to compare different zero-shot object detection models per output and latency."@en , "Library example: transformers."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Zero Shot object detection"@en .

datalens_th:robotics
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/models-tags-by-type?type=pipeline_tag> ;
      owl:seeAlso <https://www.wikidata.org/wiki/Q170978> ;
      skos:definition "Robotics is the task of improving the perception, decision-making, and interaction capabilities of robots."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Robotics"@en .

datalens_th:reinforcement-learning
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Reinforcement learning is the computational approach of learning from action by interacting with an environment through trial and error and receiving rewards (negative or positive) as feedback"@en ;
      skos:example "Dataset example: A curation of widely used datasets for Data Driven Deep Reinforcement Learning (D4RL)"@en , "Demo example: An application for a cute puppy agent learning to catch a stick."@en , "Model example: A Reinforcement Learning model trained on expert data from the Gym Hopper environment"@en , "Library example: transformers."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Reinforcement Learning"@en .

datalens_th:mask-generation
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Mask generation is the task of generating masks that identify a specific object or region of interest in a given image. Masks are often used in segmentation tasks, where they provide a precise way to isolate the object of interest for further processing or analysis."@en ;
      skos:example "Model example: Small yet powerful mask generation model."@en , "Demo example: An application that combines a mask generation model with a zero-shot object detection model for text-guided image segmentation."@en , "Dataset example: Widely used benchmark dataset for multiple Vision tasks."@en , "Library example: transformers."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Mask Generation"@en .

datalens_th:feature-extraction
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Feature extraction is the task of extracting features learnt in a model."@en ;
      skos:example "Demo example: A leaderboard to rank text feature extraction models based on a benchmark."@en , "Model example: A powerful feature extraction model for natural language processing tasks."@en , "Dataset example: Wikipedia dataset containing cleaned articles of all languages. Can be used to train `feature-extraction` models."@en , "Library example: sentence-transformers."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Feature Extraction"@en .

datalens_th:text-to-audio
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/models-tags-by-type?type=pipeline_tag> ;
      owl:seeAlso <https://huggingface.co/tasks/text-to-speech> ;
      skos:definition "Text-to-audio, also known as text-to-speech (TTS), is the task of generating natural sounding speech given text input."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Text-to-Audio"@en .

datalens_th:audio-to-audio
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Audio-to-Audio is a family of tasks in which the input is an audio and the output is one or multiple generated audios. Some example tasks are speech enhancement and source separation."@en ;
      skos:example "Demo example: An application for speech separation."@en , "Library example: asteroid."@en , "Model example: A speech enhancement model."@en , "Dataset example: 512-element X-vector embeddings of speakers from CMU ARCTIC dataset."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Audio-to-Audio"@en .

datalens_th:image-to-video
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-to-video models take a still image as input and generate a video. These models can be guided by text prompts to influence the content and style of the output video."@en ;
      skos:example "Library example: diffusers."@en , "Dataset example: A benchmark dataset for reference image controlled video generation."@en , "Demo example: An application to generate videos fast."@en , "Model example: LTX-Video, a 13B parameter model for high quality video generation"@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Image-to-Video"@en .

datalens_th:video-classification
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Video classification is the task of assigning a label or class to an entire video. Videos are expected to have only one class for each video. Video classification models take a video as input and return a prediction about which class the video belongs to."@en ;
      skos:example "Demo example: An application that classifies video at different timestamps."@en , "Dataset example: Benchmark dataset used for video classification with videos that belong to 400 classes."@en , "Library example: transformers."@en , "Model example: Strong Video Classification model trained on the Kinetics 400 dataset."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Video Classification"@en .

datalens_th:tabular-to-text
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_categories> ;
      skos:definition "Tabular-to-text is the task of converting structured tabular data into fluent and coherent natural language text."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Tabular-to-Text"@en .

datalens_th:fill-mask
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Masked language modeling is the task of masking some of the words in a sentence and predicting which words should replace those masks. These models are useful when we want to get a statistical understanding of the language in which the model is trained in."@en ;
      skos:example "Dataset example: A common dataset that is used to train models for many languages."@en , "Model example: State-of-the-art masked language model."@en , "Library example: transformers."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Fill Mask"@en .

datalens_th:object-detection
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Object Detection models allow users to identify objects of certain defined classes. Object detection models receive an image as input and output the images with bounding boxes and labels on detected objects."@en ;
      skos:example "Dataset example: Widely used benchmark dataset for multiple vision tasks."@en , "Model example: Solid object detection model pre-trained on the COCO 2017 dataset."@en , "Demo example: Real-time object detection demo."@en , "Library example: transformers."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Object Detection"@en .

datalens_th:zero-shot-image-classification
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Zero-shot image classification is the task of classifying previously unseen classes during training of a model."@en ;
      skos:example "Model example: Multilingual image classification model for 80 languages."@en , "Library example: transformers."@en , "Demo example: An application that leverages zero-shot image classification to find best captions to generate an image."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Zero Shot image classification"@en .

datalens_th:token-classification
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Token classification is a natural language understanding task in which a label is assigned to some tokens in a text. Some popular token classification subtasks are Named Entity Recognition (NER) and Part-of-Speech (PoS) tagging. NER models could be trained to identify specific entities in a text, such as dates, individuals and places; and PoS tagging would identify, for example, which words in a text are verbs, nouns, and punctuation marks."@en ;
      skos:example "Dataset example: A widely used dataset useful to benchmark named entity recognition models."@en , "Demo example: An application that can recognizes entities, extracts noun chunks and recognizes various linguistic features of each token."@en , "Library example: adapter-transformers."@en , "Model example: A robust performance model to identify people, locations, organizations and names of miscellaneous entities."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Token Classification"@en .

datalens_th:image-feature-extraction
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image feature extraction is the task of extracting features learnt in a computer vision model."@en ;
      skos:example "Model example: A powerful image feature extraction model."@en , "Dataset example: ImageNet-1K is a image classification dataset in which images are used to train image-feature-extraction models."@en , "Library example: timm."@en , "Demo example: A leaderboard to evaluate different image-feature-extraction models on classification performances"@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Image Feature Extraction"@en .

datalens_th:text-to-video
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text-to-video models can be used in any application that requires generating consistent sequence of images from text."@en ;
      skos:example "Library example: diffusers."@en , "Demo example: An application that generates video from text."@en , "Dataset example: Microsoft Research Video to Text is a large-scale dataset for open domain video captioning"@en , "Model example: A strong model for consistent video generation."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Text-to-Video"@en .

datalens_th:image-classification
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image classification is the task of assigning a label or class to an entire image. Images are expected to have only one class for each image. Image classification models take an image as input and return a prediction about which class the image belongs to."@en ;
      skos:example "Demo example: A leaderboard to evaluate different image classification models."@en , "Model example: A strong image classification model."@en , "Library example: keras."@en , "Dataset example: Benchmark dataset used for image classification with images that belong to 100 classes."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Image Classification"@en .

datalens_th:text-generation
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Generating text is the task of generating new text given another text. These models can, for example, fill in incomplete text or paraphrase."@en ;
      skos:example "Model example: A text-generation model trained to follow instructions."@en , "Demo example: An application that writes and executes code from text instructions and supports many models."@en , "Dataset example: Multilingual dataset used to evaluate text generation models."@en , "Library example: transformers."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Text Generation"@en .

datalens_th:tabular-classification
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Tabular classification is the task of classifying a target category (a group) based on set of attributes."@en ;
      skos:example "Demo example: An application that can predict defective products on a production line."@en , "Dataset example: A comprehensive curation of datasets covering all benchmarks."@en , "Model example: Breast cancer prediction model based on decision trees."@en , "Library example: sklearn."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Tabular Classification"@en .

datalens_th:multiple-choice
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_categories> ;
      owl:seeAlso <https://www.wikidata.org/wiki/Q28060611> , <https://www.wikidata.org/wiki/Q867668> , <https://huggingface.co/docs/transformers/tasks/multiple_choice> ;
      skos:definition "A multiple choice task is similar to question answering, except several candidate answers are provided along with a context and the model is trained to select the correct answer."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Multiple Choice"@en .

datalens_th:image-text-to-text
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-text-to-text models take in an image and text prompt and output text. These models are also called vision-language models, or VLMs. The difference from image-to-text models is that these models take an additional text input, not restricting the model to certain use cases like image captioning, and may also be trained to accept a conversation as input."@en ;
      skos:example "Model example: Small and efficient yet powerful vision language model."@en , "Demo example: Leaderboard to evaluate vision language models."@en , "Library example: transformers."@en , "Dataset example: Instructions composed of image and text."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Image Text-to-Text"@en .

datalens_th:visual-question-answering
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Visual Question Answering is the task of answering open-ended questions based on an image. They output natural language responses to natural language questions."@en ;
      skos:example "Model example: A visual question answering model trained to convert charts and plots to text."@en , "Library example: transformers."@en , "Demo example: An application that compares visual question answering models across different tasks."@en , "Dataset example: A widely used dataset containing questions (with answers) about images."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Visual Question Answering"@en .

datalens_th:summarization
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Summarization is the task of producing a shorter version of a document while preserving its important information. Some models can extract text from the original input, while other models can generate entirely new text."@en ;
      skos:example "Model example: A strong summarization model trained on English news articles. Excels at generating factual summaries."@en , "Dataset example: News articles in five different languages along with their summaries. Widely used for benchmarking multilingual summarization models."@en , "Demo example: An application that can summarize long paragraphs."@en , "Library example: transformers."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Summarization"@en .

datalens_th:image-text-to-image
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-text-to-image models take an image and a text prompt as input and generate a new image based on the reference image and text instructions. These models are useful for image editing, style transfer, image variations, and guided image generation tasks."@en ;
      skos:example "Demo example: An application for image-text-to-image generation."@en , "Library example: diffusers."@en , "Model example: A powerful model for image-text-to-image generation."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Image Text-to-Image"@en .

datalens_th:sentence-similarity
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Sentence Similarity is the task of determining how similar two texts are. Sentence similarity models convert input texts into vectors (embeddings) that capture semantic information and calculate how close (similar) they are between them. This task is particularly useful for information retrieval and clustering/grouping."@en ;
      skos:example "Model example: This model works well for sentences and paragraphs and can be used for clustering/grouping and semantic searches."@en , "Dataset example: Bing queries with relevant passages from various web sources."@en , "Demo example: An application that leverages sentence similarity to answer questions from YouTube videos."@en , "Library example: sentence-transformers."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Sentence Similarity"@en .

datalens_th:text-to-3d
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Text-to-3D models take in text input and produce 3D output."@en ;
      skos:example "Library example: diffusers."@en , "Demo example: Text-to-3D demo with mesh outputs."@en , "Model example: Text-to-3D mesh model by OpenAI"@en , "Dataset example: A large dataset of over 10 million 3D objects."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Text-to-3D"@en .

datalens_th:video-text-to-text
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Video-text-to-text models take in a video and a text prompt and output text. These models are also called video-language models."@en ;
      skos:example "Demo example: An application to chat with a video-text-to-text model."@en , "Model example: A robust video-text-to-text model."@en , "Library example: transformers."@en , "Dataset example: Multiple-choice questions and answers about videos."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Video Text-to-Text"@en .

datalens_th:image-to-3d
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-to-3D models take in image input and produce 3D output."@en ;
      skos:example "Model example: Fast image-to-3D mesh model by Tencent."@en , "Library example: diffusers."@en , "Demo example: Leaderboard to evaluate image-to-3D models."@en , "Dataset example: A large dataset of over 10 million 3D objects."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Image-to-3D"@en .

datalens_th:visual-document-retrieval
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Visual document retrieval is the task of searching for relevant image-based documents, such as PDFs. These models take a text query and multiple documents as input and return the top-most relevant documents and relevancy scores as output."@en ;
      skos:example "Model example: Very accurate visual document retrieval model for multilingual queries and documents."@en , "Dataset example: A large dataset used to train visual document retrieval models."@en , "Library example: transformers."@en , "Demo example: A leaderboard of visual document retrieval models."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Visual Document Retrieval"@en .

datalens_th:automatic-speech-recognition
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Automatic Speech Recognition (ASR), also known as Speech to Text (STT), is the task of transcribing a given audio to text. It has many applications, such as voice user interfaces."@en ;
      skos:example "Demo example: A powerful general-purpose speech recognition application."@en , "Model example: A powerful ASR model by OpenAI."@en , "Dataset example: 31,175 hours of multilingual audio-text dataset in 108 languages."@en , "Library example: espnet."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Automatic Speech Recognition"@en .

datalens_th:audio-text-to-text
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Audio-text-to-text models take both an audio clip and a text prompt as input, and generate natural language text as output. These models can answer questions about spoken content, summarize meetings, analyze music, or interpret speech beyond simple transcription. They are useful for applications that combine speech understanding with reasoning or conversation."@en ;
      skos:example "Dataset example: A dataset containing audio conversations with question–answer pairs."@en , "Library example: transformers."@en , "Demo example: A space that takes input as both audio and text and generates answers."@en , "Model example: A lightweight model that has capabilities of taking both audio and text as inputs and generating responses."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Audio Text-to-Text"@en .

datalens_th:text-retrieval
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_categories> ;
      owl:seeAlso <https://www.wikidata.org/wiki/Q816826> ;
      skos:definition "Text retrieval is the task of obtaining information resources relevant to an information need from text."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Text Retrieval"@en .

datalens_th:depth-estimation
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Depth estimation is the task of predicting depth of the objects present in an image."@en ;
      skos:example "Model example: Cutting-edge depth estimation model."@en , "Dataset example: NYU Depth V2 Dataset: Video dataset containing both RGB and depth sensor data."@en , "Library example: transformers."@en , "Demo example: An application that predicts the depth of an image and then reconstruct the 3D model as voxels."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Depth Estimation"@en .

datalens_th:table-to-text
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/datasets-tags-by-type?type=task_categories> ;
      skos:definition "Table-to-text is the task of converting structured tabular data into fluent and coherent natural language text."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Table-to-Text"@en .

datalens_th:image-text-to-video
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image-text-to-video models take an reference image and a text instructions as and generate a video based on them. These models are useful for animating still images, creating dynamic content from static references, and generating videos with specific motion or transformation guidance."@en ;
      skos:example "Library example: diffusers."@en , "Model example: A powerful model for image-text-to-video generation."@en , "Demo example: An application for image-text-to-video generation."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Image Text-to-Video"@en .

datalens_th:table-question-answering
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Table Question Answering (Table QA) is the answering a question about an information on a given table."@en ;
      skos:example "Demo example: An application that answers questions based on table CSV files."@en , "Dataset example: The WikiTableQuestions dataset is a large-scale dataset for the task of question answering on semi-structured tables."@en , "Library example: transformers."@en , "Model example: A table question answering model that is capable of neural SQL execution, i.e., employ TAPEX to execute a SQL query on a given table."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Table Question Answering"@en .

datalens_th:question-answering
      a       datalens_o:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Question Answering models can retrieve the answer to a question from a given text, which is useful for searching for an answer in a document. Some question answering models can generate answers without context!"@en ;
      skos:example "Library example: adapter-transformers."@en , "Demo example: An application that can answer a long question from Wikipedia."@en , "Dataset example: A famous question answering dataset based on English articles from Wikipedia."@en , "Model example: A robust baseline model for most question answering domains."@en ;
      skos:inScheme datalens_th:TaskScheme ;
      skos:prefLabel "Question Answering"@en .

datalens_th:graph-ml
