mluo_th:image-classification
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Image classification is the task of assigning a label or class to an entire image. Images are expected to have only one class for each image. Image classification models take an image as input and return a prediction about which class the image belongs to."@en ;
