mluo_th:fill-mask
      a       mluo:TaskCategory , skos:Concept ;
      dcterms:source <https://huggingface.co/api/tasks> ;
      skos:definition "Masked language modeling is the task of masking some of the words in a sentence and predicting which words should replace those masks. These models are useful when we want to get a statistical understanding of the language in which the model is trained in."@en ;
      skos:inScheme mluo_th:nlp ;
      skos:prefLabel "Fill Mask"@en ;
      skos:topConceptOf mluo_th:nlp .

