@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#>.
@prefix schema: <http://schema.org/> .
@prefix rr:     <http://www.w3.org/ns/r2rml#> .
@prefix rml:    <http://semweb.mmlab.be/ns/rml#> .
@prefix xrr:    <http://i3s.unice.fr/xr2rml#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

@prefix mluo: <http://example.org/mluo/ontology#> .
@prefix mluo_th: <http://example.org/mluo/thesaurus#> .

<#Libraries>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.libraries.find({}, {_id:0})";
        rml:iterator "$.library.*";
    ];
    rr:subjectMap [ 
        rr:template "http://example.org/mluo/thesaurus#{$.id}"; 
        rr:termType rr:IRI;
		rr:class mluo:Library;
        rr:class skos:Concept;
    ];
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel ;
        rr:objectMap [ xrr:reference "$.label"; rr:language "en"  ];
    ];
    rr:predicateObjectMap [
        rr:predicate skos:inScheme;
        rr:objectMap [ rr:constant mluo_th:LibraryScheme; rr:termType rr:IRI ];
    ];
    .

<#LibrariesScheme>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.libraries.findOne({}, {_id:0})";
        rml:iterator "$";
    ];
    rr:subjectMap [
        rr:constant mluo_th:LibraryScheme;
        rr:termType rr:IRI;
        rr:class skos:ConceptScheme;
    ];
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel;
        rr:objectMap [ rr:constant "Model Library Scheme"; rr:language "en" ];
    ];
    rr:predicateObjectMap [
        rr:predicate skos:definition;
        rr:objectMap [ rr:constant "A controlled vocabulary for describing the libraries of machine learning models."; rr:language "en" ];
    ];
    .