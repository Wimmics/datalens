    rr:predicateObjectMap [ rr:predicate mluo:hasModality; rr:objectMap [ rr:template "http://example.org/mluo/thesaurus#{$.modality}"; rr:termType rr:IRI ]; ];
    .

<#DatasetLanguage>
    a rr:TriplesMap;
    xrr:logicalSource [
        xrr:query "db.datasets_languages.find({dataset_hash16:{$exists:true}, language:{$exists:true,$ne:null}})";
